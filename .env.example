# PostgreSQL Supabase : Tableau de bord → Project Settings → Database → Connection string → URI
# Remplace [YOUR-PASSWORD] par le mot de passe base (pas la clé anon).
# Préfère l’hôte direct (port 5432) pour `prisma db push` / migrations.
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# API Supabase (optionnel tant que l’app n’utilise que Prisma)
SUPABASE_URL="https://[PROJECT-REF].supabase.co"
SUPABASE_ANON_KEY="eyJ..."
# Clé secrète (service_role) : uniquement serveur, jamais dans le front ni dans Git.
# Obligatoire pour inscription, invitation équipe, clients portail (création compte Supabase Auth).
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

PORT=3000
# Ne pas réutiliser ces libellés en production : générez des secrets longs et uniques (Netlify, local).
JWT_ACCESS_SECRET="REPLACE_WITH_STRONG_RANDOM_SECRET_MIN_32_CHARS"
JWT_REFRESH_SECRET="REPLACE_WITH_ANOTHER_STRONG_RANDOM_SECRET"
DEV_BYPASS_AUTH="false"
# Local : 127.0.0.1 évite la collision avec certaines valeurs « localhost » côté hébergeur.
APP_BASE_URL="http://127.0.0.1:3000"
# Netlify / HTTPS : mettre l’URL exacte du site (https://…) pour cookies CSRF + JWT « Secure ».
# Ex. APP_BASE_URL="https://cleanserviceb.netlify.app"
# Forcer les cookies : COOKIE_SECURE=true ou COOKIE_SECURE=false

# Netlify / hébergeur serverless : les tâches cron (factures, file mails) ne tournent pas comme en local.
SMTP_HOST="127.0.0.1"
SMTP_PORT=1025
SMTP_USER=""
SMTP_PASS=""
# Expediteur Nodemailer (invitations équipe, rappels). En prod : votre domaine, ex. défini dans Netlify.
MAIL_FROM="noreply@votredomaine.example"
# Les liens « définir le mot de passe » (inscription) partent de Supabase : Auth → SMTP / expéditeur.
