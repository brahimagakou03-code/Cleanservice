<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8">
    <title>Verification OTP — inscription</title>
    <%- include("partials/favicon") %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/public/styles/app.css" rel="stylesheet">
  </head>
  <body class="bg-light">
    <%- include("partials/auth-header", { mode: "staff" }) %>
    <div class="container py-4" style="max-width:560px;">
      <div class="text-center mb-4">
        <img src="<%= typeof platformLogoUrl !== 'undefined' ? platformLogoUrl : '/branding/logo.png' %>" class="cs-logo-hero" alt="Clean Service">
      </div>
      <h1 class="h3">Verification du code OTP</h1>
      <p class="small text-muted">
        Un code a ete envoye a <strong><%= email || "" %></strong>. Saisissez-le ci-dessous pour valider votre inscription.
      </p>
      <% if (typeof error !== "undefined" && error) { %>
        <div class="alert alert-warning" role="alert"><%= error %></div>
      <% } %>
      <% if (typeof success !== "undefined" && success) { %>
        <div class="alert alert-success" role="alert"><%= success %></div>
      <% } %>
      <% if (signupId) { %>
        <form method="POST" action="/register/verify-otp" class="card p-3">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <input type="hidden" name="signupId" value="<%= signupId %>" />
          <label class="form-label" for="otp">Code OTP <span class="text-danger" aria-hidden="true">*</span></label>
          <input id="otp" class="form-control" name="otp" inputmode="numeric" maxlength="6" minlength="6" placeholder="123456" required autocomplete="one-time-code" />
          <button class="btn btn-primary mt-3" type="submit">Valider mon inscription</button>
        </form>
      <% } %>
      <p class="mt-3"><a href="/register">Recommencer l'inscription</a></p>
      <p class="mt-2"><a href="/login">Deja inscrit ? Se connecter</a></p>
    </div>
  </body>
</html>
