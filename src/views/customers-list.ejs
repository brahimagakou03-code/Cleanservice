<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Clients</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/public/styles/app.css" rel="stylesheet">
</head>
<body class="bg-light">
  <%- include("partials/dashboard-header") %>
  <div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h1 class="h3 mb-0">Clients</h1>
      <div class="btn-group">
        <a class="btn btn-outline-secondary" href="/dashboard">Tableau de bord</a>
        <a class="btn btn-primary" href="/dashboard/customers/new">Créer un compte client</a>
        <a class="btn btn-outline-primary" href="/dashboard/customers/import">Importer</a>
        <a class="btn btn-outline-success" href="/dashboard/customers/export/csv">Exporter CSV</a>
        <a class="btn btn-outline-success" href="/dashboard/customers/export/xlsx">Exporter Excel</a>
      </div>
    </div>

    <form method="GET" action="/dashboard/customers" class="row g-2 mb-3">
      <div class="col-md-3"><input class="form-control" name="q" placeholder="Nom, code ou email" value="<%= filters.q %>" /></div>
      <div class="col-md-2"><select class="form-select" name="isActive"><option value="">Tous statuts</option><option value="active" <%= filters.isActive==="active"?"selected":"" %>>Actifs</option><option value="inactive" <%= filters.isActive==="inactive"?"selected":"" %>>Inactifs</option></select></div>
      <div class="col-md-2"><select class="form-select" name="paymentTerms"><option value="">Toutes conditions</option><% paymentTermsOptions.forEach(function(p){ %><option value="<%= p %>" <%= filters.paymentTerms===p?"selected":"" %>><%= fr.paymentTerms(p) %></option><% }) %></select></div>
      <div class="col-md-2"><select class="form-select" name="sortBy"><option value="createdAt">Date</option><option value="code" <%= filters.sortBy==="code"?"selected":"" %>>Code</option><option value="companyName" <%= filters.sortBy==="companyName"?"selected":"" %>>Entreprise</option><option value="email" <%= filters.sortBy==="email"?"selected":"" %>>E-mail</option></select></div>
      <div class="col-md-1"><select class="form-select" name="sortDir"><option value="asc" <%= filters.sortDir==="asc"?"selected":"" %>>Croissant</option><option value="desc" <%= filters.sortDir==="desc"?"selected":"" %>>Décroissant</option></select></div>
      <div class="col-md-2"><button class="btn btn-dark w-100" type="submit">Appliquer</button></div>
    </form>

    <div class="card">
      <div class="table-responsive">
        <table class="table table-striped mb-0">
          <thead><tr><th>Code</th><th>Entreprise</th><th>E-mail</th><th>Paiement</th><th>Actif</th><th>Sites</th><% if (typeof canDeleteCustomer !== "undefined" && canDeleteCustomer) { %><th class="text-end">Actions</th><% } %></tr></thead>
          <tbody>
            <% customers.forEach(function(c) { %>
              <tr>
                <td><a href="/dashboard/customers/<%= c.id %>"><%= c.code %></a></td>
                <td><%= c.companyName %></td><td><%= c.email || "-" %></td><td><%= fr.paymentTerms(c.paymentTerms) %></td>
                <td><span class="badge <%= c.isActive ? "text-bg-success":"text-bg-secondary" %>"><%= c.isActive ? "Oui":"Non" %></span></td>
                <td><%= c.sites.length %></td>
                <% if (typeof canDeleteCustomer !== "undefined" && canDeleteCustomer) { %>
                <% const delConfirmMsg = `Supprimer définitivement le client « ${c.companyName} » (${c.code}) ?

Les commandes et factures liées seront aussi supprimées.`; %>
                <td class="text-end">
                  <form method="POST" action="/dashboard/customers/<%= c.id %>/delete" class="d-inline" onsubmit="return confirm(<%- JSON.stringify(delConfirmMsg) %>);">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                    <button type="submit" class="btn btn-sm btn-outline-danger">Supprimer</button>
                  </form>
                </td>
                <% } %>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
    <div class="mt-3 d-flex gap-2 align-items-center">
      <span>Page <%= page %> / <%= totalPages %></span>
      <% if (page > 1) { %><a class="btn btn-sm btn-outline-dark" href="/dashboard/customers?page=<%= page - 1 %>&q=<%= encodeURIComponent(filters.q) %>&isActive=<%= filters.isActive %>&paymentTerms=<%= filters.paymentTerms %>&sortBy=<%= filters.sortBy %>&sortDir=<%= filters.sortDir %>">Précédent</a><% } %>
      <% if (page < totalPages) { %><a class="btn btn-sm btn-outline-dark" href="/dashboard/customers?page=<%= page + 1 %>&q=<%= encodeURIComponent(filters.q) %>&isActive=<%= filters.isActive %>&paymentTerms=<%= filters.paymentTerms %>&sortBy=<%= filters.sortBy %>&sortDir=<%= filters.sortDir %>">Suivant</a><% } %>
    </div>
  </div>
</body>
</html>
