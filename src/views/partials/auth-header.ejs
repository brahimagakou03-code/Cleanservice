<% const headerMode = typeof mode !== "undefined" ? mode : "chooser"; %>
<nav class="navbar navbar-expand-lg cs-navbar mb-4">
  <div class="container">
    <a class="navbar-brand d-flex align-items-center gap-3" href="/">
      <img src="<%= typeof platformLogoUrl !== 'undefined' ? platformLogoUrl : '/branding/logo.png' %>" alt="Clean Service" class="cs-logo" />
    </a>
    <div class="navbar-nav ms-auto flex-row gap-2 align-items-center">
      <% if (headerMode === "staff") { %>
        <a class="nav-link cs-link py-1" href="/portal/login">Espace client</a>
        <a class="nav-link cs-link py-1" href="/super-admin/login">Super admin</a>
      <% } else if (headerMode === "portal") { %>
        <a class="nav-link cs-link py-1" href="/admin/login">Admin boutique</a>
      <% } %>
    </div>
  </div>
</nav>
