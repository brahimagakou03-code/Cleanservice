<!doctype html>
<html lang="fr">
  <head><meta charset="UTF-8"><title>Inscription</title><%- include("partials/favicon") %><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"><link href="/public/styles/app.css" rel="stylesheet"></head>
  <body class="bg-light">
    <%- include("partials/auth-header", { mode: "staff" }) %>
    <div class="container py-4" style="max-width:560px;">
    <div class="text-center mb-4"><img src="<%= typeof platformLogoUrl !== 'undefined' ? platformLogoUrl : '/branding/logo.png' %>" class="cs-logo-hero" alt="Clean Service"></div>
    <h1 class="h3">Inscription administrateur</h1>
    <% if (typeof registerAlert !== "undefined" && registerAlert) { %>
      <div class="alert alert-warning" role="alert"><%= registerAlert %></div>
    <% } %>
    <% if (typeof registerSuccess !== "undefined" && registerSuccess) { %>
      <div class="alert alert-success" role="alert"><%= registerSuccess %></div>
    <% } %>
    <form method="POST" action="/register" class="card p-3">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <p class="small text-muted mb-2"><span class="text-danger" aria-hidden="true">*</span> Champ obligatoire</p>
      <label class="form-label" for="firstName">Prénom <span class="text-danger" aria-hidden="true">*</span></label>
      <input id="firstName" class="form-control" name="firstName" required />
      <label class="form-label mt-3" for="lastName">Nom <span class="text-danger" aria-hidden="true">*</span></label>
      <input id="lastName" class="form-control" name="lastName" required />
      <label class="form-label mt-3" for="email">E-mail <span class="text-danger" aria-hidden="true">*</span></label>
      <input id="email" class="form-control" type="email" name="email" required autocomplete="email" />
      <label class="form-label mt-3" for="password">Mot de passe <span class="text-danger" aria-hidden="true">*</span></label>
      <input id="password" class="form-control" type="password" name="password" required minlength="6" autocomplete="new-password" />
      <p class="small text-muted mt-3">Mot de passe minimum 6 caractères.</p>
      <button class="btn btn-primary" type="submit">Créer mon espace</button>
    </form>
    <p class="mt-3"><a href="/login">Déjà inscrit ? Se connecter</a></p>
    </div>
  </body>
</html>
