<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8"><title>Nouveau client</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/public/styles/app.css" rel="stylesheet">
  </head>
  <body class="bg-light">
    <%- include("partials/dashboard-header") %>
    <div class="container py-4">
    <h1 class="h3 cs-page-title">Nouveau client</h1>
    <% if (errors && errors.length) { %>
      <div class="alert alert-danger"><% errors.forEach(function(e){ %><div><%= e %></div><% }) %></div>
    <% } %>
    <p class="small text-muted mb-3"><span class="text-danger" aria-hidden="true">*</span> Champ obligatoire</p>
    <form method="POST" action="/dashboard/customers" class="card p-4">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <div class="row g-3">
        <div class="col-md-6"><label class="form-label">Entreprise <span class="text-danger" aria-hidden="true">*</span></label><input class="form-control" name="companyName" required /></div>
        <div class="col-md-2"><label class="form-label">Pays (ISO2)</label><input class="form-control" name="countryCode" value="FR" /></div>
        <div class="col-md-4"><label class="form-label">SIRET</label><input class="form-control" name="siret" /></div>
        <div class="col-md-4"><label class="form-label">TVA intracommunautaire</label><input class="form-control" name="vatNumber" /></div>
        <div class="col-md-4">
          <label class="form-label">E-mail <span class="text-danger">*</span></label>
          <input class="form-control" type="email" name="email" required autocomplete="email" />
          <div class="form-text">Obligatoire : identifiant du portail client et envoi du mot de passe.</div>
        </div>
        <div class="col-md-4"><label class="form-label">Téléphone</label><input class="form-control" name="phone" /></div>
        <div class="col-md-6"><label class="form-label">Site web</label><input class="form-control" name="website" /></div>
        <div class="col-md-3"><label class="form-label">Conditions de paiement</label>
        <select class="form-select" name="paymentTerms">
          <% paymentTermsOptions.forEach(function(p) { %>
            <option value="<%= p %>"><%= fr.paymentTerms(p) %></option>
          <% }) %>
        </select>
        </div>
        <div class="col-md-2"><label class="form-label d-block">Actif</label><input class="form-check-input" type="checkbox" name="isActive" checked /></div>
        <div class="col-12"><label class="form-label">Notes</label><textarea class="form-control" name="notes" rows="3"></textarea></div>
      </div>

      <hr class="my-4" />
      <h2 class="h5 mb-2">Sites — plusieurs dès la création</h2>
      <p class="text-muted small mb-3">Renseignez <strong>autant de sites que nécessaire</strong> maintenant (siège, entrepôt, succursale…). Laissez une ligne vide ou cliquez « Retirer » si elle ne sert pas. Vous pourrez toujours en ajouter ou les modifier plus tard dans la fiche client, onglet <strong>Sites</strong>.</p>
      <div id="sites-container">
        <div class="site-row card border p-3 mb-3 bg-white" data-site-row>
          <div class="d-flex justify-content-between align-items-center mb-2">
            <span class="small text-muted fw-medium site-row-label">Site 1</span>
            <button type="button" class="btn btn-sm btn-outline-danger site-row-remove d-none" aria-label="Retirer ce site">Retirer</button>
          </div>
          <div class="row g-3">
            <div class="col-md-4"><label class="form-label">Libellé <span class="text-danger" aria-hidden="true">*</span></label><input class="form-control" name="siteLabel" value="Siège" required /></div>
            <div class="col-md-8"><label class="form-label">Adresse complète <span class="text-danger" aria-hidden="true">*</span></label><textarea class="form-control" name="siteAddress" required rows="2" placeholder="Adresse postale complète"></textarea></div>
            <div class="col-md-4"><label class="form-label">Nom du contact</label><input class="form-control" name="siteContactName" /></div>
            <div class="col-md-4"><label class="form-label">E-mail du contact</label><input class="form-control" name="siteContactEmail" /></div>
            <div class="col-md-4"><label class="form-label">Téléphone du contact</label><input class="form-control" name="siteContactPhone" /></div>
          </div>
        </div>
        <div class="site-row card border p-3 mb-3 bg-white" data-site-row>
          <div class="d-flex justify-content-between align-items-center mb-2">
            <span class="small text-muted fw-medium site-row-label">Site 2</span>
            <button type="button" class="btn btn-sm btn-outline-danger site-row-remove" aria-label="Retirer ce site">Retirer</button>
          </div>
          <div class="row g-3">
            <div class="col-md-4"><label class="form-label">Libellé</label><input class="form-control" name="siteLabel" placeholder="Ex. Entrepôt, Succursale…" autocomplete="off" /></div>
            <div class="col-md-8"><label class="form-label">Adresse complète</label><textarea class="form-control" name="siteAddress" rows="2" placeholder="Optionnel tant que la ligne est vide"></textarea></div>
            <div class="col-md-4"><label class="form-label">Nom du contact</label><input class="form-control" name="siteContactName" /></div>
            <div class="col-md-4"><label class="form-label">E-mail du contact</label><input class="form-control" name="siteContactEmail" /></div>
            <div class="col-md-4"><label class="form-label">Téléphone du contact</label><input class="form-control" name="siteContactPhone" /></div>
          </div>
        </div>
      </div>
      <button type="button" class="btn btn-outline-primary btn-sm" id="add-site-row">+ Ajouter un autre site</button>

      <button class="btn btn-primary mt-4 d-block" type="submit">Créer le client</button>
    </form>
    <p class="mt-3"><a class="btn btn-outline-secondary" href="/dashboard/customers">Retour</a></p>
    </div>
    <script>
      (function () {
        const container = document.getElementById("sites-container");
        const addBtn = document.getElementById("add-site-row");
        if (!container || !addBtn) return;
        function renumber() {
          const rows = container.querySelectorAll("[data-site-row]");
          rows.forEach(function (row, i) {
            const lab = row.querySelector(".site-row-label");
            if (lab) lab.textContent = "Site " + (i + 1);
            const rm = row.querySelector(".site-row-remove");
            if (rm) rm.classList.toggle("d-none", rows.length <= 1);
          });
        }
        addBtn.addEventListener("click", function () {
          const first = container.querySelector("[data-site-row]");
          if (!first) return;
          const clone = first.cloneNode(true);
          clone.querySelectorAll("input, textarea").forEach(function (el) {
            el.value = "";
          });
          const lab = clone.querySelector('input[name="siteLabel"]');
          const addr = clone.querySelector('textarea[name="siteAddress"]');
          if (lab) {
            lab.required = false;
            lab.placeholder = "Ex. Entrepôt, Succursale…";
          }
          if (addr) addr.required = false;
          container.appendChild(clone);
          renumber();
        });
        container.addEventListener("click", function (e) {
          const btn = e.target.closest(".site-row-remove");
          if (!btn) return;
          const row = btn.closest("[data-site-row]");
          if (!row || container.querySelectorAll("[data-site-row]").length <= 1) return;
          row.remove();
          renumber();
          const first = container.querySelector("[data-site-row]");
          if (first) {
            const l = first.querySelector('input[name="siteLabel"]');
            const a = first.querySelector('textarea[name="siteAddress"]');
            if (l) l.required = true;
            if (a) a.required = true;
          }
        });
        renumber();
      })();
    </script>
  </body>
</html>
