<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Commandes</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/public/styles/app.css" rel="stylesheet">
</head>
<body class="bg-light">
<%- include("partials/dashboard-header") %>
<div class="container py-4">
  <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <h1 class="h3 mb-0">Commandes</h1>
    <a class="btn btn-primary" href="/dashboard/orders/new">Nouvelle commande</a>
  </div>

  <div class="card cs-orders-filters mb-4">
    <div class="card-body">
      <h2 class="h6 text-muted mb-3">Filtrer les commandes</h2>
      <form method="GET" action="/dashboard/orders">
        <div class="row g-3 align-items-end">
          <div class="col-12 col-lg-3">
            <label class="form-label cs-filter-label" for="f-q">Recherche</label>
            <input id="f-q" class="form-control" name="q" value="<%= filters.q %>" placeholder="N° ou nom client" autocomplete="off">
          </div>
          <div class="col-12 col-md-6 col-lg-3">
            <label class="form-label cs-filter-label" for="f-client">Client</label>
            <select id="f-client" class="form-select" name="customerId">
              <option value="">Tous les clients</option>
              <% customers.forEach(function(c){ %>
                <option value="<%= c.id %>" <%= filters.customerId===c.id?'selected':'' %>><%= c.companyName %></option>
              <% }) %>
            </select>
          </div>
          <div class="col-6 col-md-3 col-lg-2">
            <label class="form-label cs-filter-label" for="f-from">Créée du</label>
            <input id="f-from" class="form-control" name="fromDate" type="date" value="<%= filters.fromDate %>">
          </div>
          <div class="col-6 col-md-3 col-lg-2">
            <label class="form-label cs-filter-label" for="f-to">Créée au</label>
            <input id="f-to" class="form-control" name="toDate" type="date" value="<%= filters.toDate %>">
          </div>
          <div class="col-6 col-md-3 col-lg-1">
            <label class="form-label cs-filter-label text-nowrap" for="f-min" title="Montant TTC minimum">TTC min.</label>
            <input id="f-min" class="form-control" name="minAmount" inputmode="decimal" placeholder="0" value="<%= filters.minAmount %>">
          </div>
          <div class="col-6 col-md-3 col-lg-1">
            <label class="form-label cs-filter-label text-nowrap" for="f-max" title="Montant TTC maximum">TTC max.</label>
            <input id="f-max" class="form-control" name="maxAmount" inputmode="decimal" placeholder="" value="<%= filters.maxAmount %>">
          </div>
        </div>

        <hr class="my-3 text-muted opacity-25">

        <div class="mb-2">
          <span class="form-label cs-filter-label d-block mb-2">Statuts <span class="fw-normal text-muted small">(plusieurs choix possibles)</span></span>
          <div class="cs-status-grid">
            <% statuses.forEach(function(s){ %>
              <div class="form-check">
                <input class="form-check-input" type="checkbox" name="statuses" value="<%= s %>" id="st-<%= s %>" <%= filters.statuses.includes(s)?'checked':'' %>>
                <label class="form-check-label" for="st-<%= s %>"><%= fr.orderStatus(s) %></label>
              </div>
            <% }) %>
          </div>
        </div>

        <div class="d-flex flex-wrap gap-2 mt-3 pt-1">
          <button type="submit" class="btn btn-primary px-4">Appliquer les filtres</button>
          <a href="/dashboard/orders" class="btn btn-outline-secondary">Réinitialiser</a>
        </div>
      </form>
    </div>
  </div>

  <div class="table-responsive card border-0 shadow-sm">
    <table class="table table-striped mb-0 align-middle cs-orders-list-table">
      <colgroup>
        <col class="cs-olc-numero" />
        <col class="cs-olc-client" />
        <col class="cs-olc-statut" />
        <col class="cs-olc-actions" />
        <col class="cs-olc-ht" />
        <col class="cs-olc-tva" />
        <col class="cs-olc-ttc" />
        <col class="cs-olc-date" />
      </colgroup>
      <thead class="table-light">
        <tr>
          <th scope="col">Numéro</th>
          <th scope="col">Client</th>
          <th scope="col">Statut</th>
          <th scope="col" class="cs-olc-actions-head">Actions logistiques</th>
          <th scope="col" class="text-end text-nowrap cs-olc-money">HT</th>
          <th scope="col" class="text-end text-nowrap cs-olc-money">TVA</th>
          <th scope="col" class="text-end text-nowrap cs-olc-money">TTC</th>
          <th scope="col" class="text-nowrap">Date</th>
        </tr>
      </thead>
      <tbody>
        <% const statusColor = {DRAFT:'secondary',PENDING_APPROVAL:'warning',CONFIRMED:'primary',IN_PREPARATION:'info',SHIPPED:'dark',DELIVERED:'success',CANCELLED:'danger'}; %>
        <% function rowMoney(v) { var n = Number(v || 0); return n.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, '\u202f'); } %>
        <% orders.forEach(function(o){ %>
          <tr>
            <td class="text-nowrap"><a href="/dashboard/orders/<%= o.id %>"><%= o.number %></a></td>
            <td class="cs-olc-client-cell" title="<%= o.customer.companyName %>"><%= o.customer.companyName %></td>
            <td class="cs-olc-statut-cell"><span class="badge text-bg-<%= statusColor[o.status] || 'secondary' %>"><%= fr.orderStatus(o.status) %></span></td>
            <td class="cs-olc-actions-cell">
              <% if (o.status === "IN_PREPARATION") { %>
                <form method="POST" action="/dashboard/orders/<%= o.id %>/status" class="d-inline-flex">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <input type="hidden" name="toStatus" value="SHIPPED">
                  <button class="btn btn-sm btn-outline-dark text-nowrap">Marquer expédiée</button>
                </form>
              <% } else if (o.status === "SHIPPED") { %>
                <form method="POST" action="/dashboard/orders/<%= o.id %>/status" class="d-inline-flex">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <input type="hidden" name="toStatus" value="DELIVERED">
                  <button class="btn btn-sm btn-outline-success text-nowrap">Marquer livrée</button>
                </form>
              <% } else { %>
                <span class="text-muted small">—</span>
              <% } %>
            </td>
            <td class="text-end font-monospace text-nowrap cs-olc-money"><%= rowMoney(o.totalHt) %></td>
            <td class="text-end font-monospace text-nowrap cs-olc-money"><%= rowMoney(o.totalTva) %></td>
            <td class="text-end font-monospace text-nowrap cs-olc-money"><%= rowMoney(o.totalTtc) %></td>
            <td class="text-nowrap"><%= o.createdAt.toISOString().slice(0,10) %></td>
          </tr>
        <% }) %>
      </tbody>
      <tfoot class="table-group-divider">
        <tr>
          <th colspan="4" scope="row" class="text-start">Totaux (page)</th>
          <th class="text-end font-monospace text-nowrap cs-olc-money"><%= footer.totalHt %></th>
          <th class="text-end font-monospace text-nowrap cs-olc-money"><%= footer.totalTva %></th>
          <th class="text-end font-monospace text-nowrap cs-olc-money"><%= footer.totalTtc %></th>
          <th></th>
        </tr>
      </tfoot>
    </table>
  </div>

  <div class="d-flex flex-wrap align-items-center gap-2 mt-3">
    <span class="text-muted small">Page <%= page %> / <%= totalPages %></span>
    <% if(page>1){ %><a class="btn btn-sm btn-outline-dark" href="<%= pageHref(page-1) %>">Précédent</a><% } %>
    <% if(page<totalPages){ %><a class="btn btn-sm btn-outline-dark" href="<%= pageHref(page+1) %>">Suivant</a><% } %>
  </div>
</div>
</body>
</html>
