<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Paramètres équipe</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/public/styles/app.css" rel="stylesheet">
</head>
<body class="bg-light">
<%- include("partials/dashboard-header") %>
<div class="container py-4">
  <h1 class="h3 cs-page-title mb-2">Gestion de l’équipe</h1>
  <p class="text-muted small mb-4">Votre rôle : <span class="badge bg-primary"><%= fr.role(role) %></span></p>

  <div class="card cs-tool-card mb-4">
    <div class="card-header">Inviter un membre</div>
    <div class="card-body">
      <form method="POST" action="/dashboard/settings/team/invite" class="row g-3 align-items-end">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <div class="col-md-4">
          <label class="form-label small fw-semibold">E-mail <span class="text-danger">*</span></label>
          <input class="form-control" type="email" name="email" required placeholder="collegue@entreprise.fr" />
        </div>
        <div class="col-md-3">
          <label class="form-label small fw-semibold">Prénom</label>
          <input class="form-control" name="firstName" placeholder="Prénom" />
        </div>
        <div class="col-md-3">
          <label class="form-label small fw-semibold">Nom</label>
          <input class="form-control" name="lastName" placeholder="Nom" />
        </div>
        <div class="col-md-2">
          <label class="form-label small fw-semibold">Rôle</label>
          <select class="form-select" name="role">
            <% roles.forEach(function(r) { %>
              <option value="<%= r %>"><%= fr.role(r) %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-12">
          <button type="submit" class="btn btn-primary">Envoyer l’invitation</button>
        </div>
      </form>
    </div>
  </div>

  <div class="card cs-tool-card">
    <div class="card-header">Membres</div>
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="cs-table-tools mb-0">
          <thead>
            <tr>
              <th>Nom</th>
              <th>E-mail</th>
              <th>Rôle</th>
              <th>Statut</th>
              <th class="text-end">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% members.forEach(function(m) { %>
              <tr>
                <td class="fw-medium"><%= m.firstName %> <%= m.lastName %></td>
                <td><%= m.email %></td>
                <td>
                  <form method="POST" action="/dashboard/settings/team/<%= m.id %>/role" class="d-flex flex-wrap align-items-center gap-2">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                    <select class="form-select form-select-sm" name="role" style="max-width:11rem">
                      <% roles.forEach(function(r) { %>
                        <option value="<%= r %>" <%= m.role === r ? "selected" : "" %>><%= fr.role(r) %></option>
                      <% }) %>
                    </select>
                    <button type="submit" class="btn btn-sm btn-outline-primary">Mettre à jour</button>
                  </form>
                </td>
                <td>
                  <% if (m.isActive) { %>
                    <span class="badge text-bg-success">Actif</span>
                  <% } else { %>
                    <span class="badge text-bg-secondary">Inactif</span>
                  <% } %>
                </td>
                <td class="text-end">
                  <form method="POST" action="/dashboard/settings/team/<%= m.id %>/toggle-active" class="d-inline">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                    <button type="submit" class="btn btn-sm <%= m.isActive ? "btn-outline-danger" : "btn-outline-success" %>">
                      <%= m.isActive ? "Désactiver" : "Activer" %>
                    </button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <p class="mt-4 mb-0"><a class="btn btn-outline-secondary" href="/dashboard">← Retour au tableau de bord</a></p>
</div>
</body>
</html>
