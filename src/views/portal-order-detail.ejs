<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= order.number %> — Détail commande</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/public/styles/app.css" rel="stylesheet">
</head>
<body class="bg-light">
  <%- include("partials/portal-header") %>
  <div class="container py-4 pb-5">
    <nav aria-label="fil d'Ariane" class="mb-3">
      <ol class="breadcrumb mb-0 small">
        <li class="breadcrumb-item"><a href="/portal">Accueil</a></li>
        <li class="breadcrumb-item"><a href="/portal/commandes">Historique des commandes</a></li>
        <li class="breadcrumb-item active" aria-current="page"><%= order.number %></li>
      </ol>
    </nav>

    <div class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-4">
      <div>
        <h1 class="h4 mb-1">Commande <%= order.number %></h1>
        <p class="cs-subtle small mb-0">Passée le <%= new Date(order.createdAt).toLocaleDateString("fr-FR", { weekday: "long", day: "numeric", month: "long", year: "numeric" }) %></p>
      </div>
      <% const statusBadge = { DRAFT: "secondary", PENDING_APPROVAL: "warning", CONFIRMED: "primary", IN_PREPARATION: "info", SHIPPED: "dark", DELIVERED: "success", CANCELLED: "danger" }; %>
      <span class="badge text-bg-<%= statusBadge[order.status] || "secondary" %> fs-6"><%= fr.orderStatus(order.status) %></span>
    </div>

    <div class="row g-3 mb-4">
      <div class="col-md-6">
        <div class="card border-0 shadow-sm h-100">
          <div class="card-header bg-white py-2 small fw-semibold">Livraison</div>
          <div class="card-body small">
            <% if (order.deliverySite) { %>
              <p class="mb-1"><strong><%= order.deliverySite.label %></strong></p>
              <p class="mb-0 text-muted"><%= order.deliverySite.fullAddress %></p>
            <% } else { %>
              <p class="text-muted mb-0">—</p>
            <% } %>
          </div>
        </div>
      </div>
      <div class="col-md-6">
        <div class="card border-0 shadow-sm h-100">
          <div class="card-header bg-white py-2 small fw-semibold">Facturation</div>
          <div class="card-body small">
            <% if (order.billingSite) { %>
              <p class="mb-1"><strong><%= order.billingSite.label %></strong></p>
              <p class="mb-0 text-muted"><%= order.billingSite.fullAddress %></p>
            <% } else { %>
              <p class="text-muted mb-0">—</p>
            <% } %>
          </div>
        </div>
      </div>
    </div>

    <% if (order.requestedDeliveryDate) { %>
      <p class="small text-muted mb-3">Date de livraison souhaitée : <strong><%= new Date(order.requestedDeliveryDate).toLocaleDateString("fr-FR") %></strong></p>
    <% } %>
    <% if (order.notes) { %>
      <div class="alert alert-light border small mb-4"><strong>Votre commentaire :</strong> <%= order.notes %></div>
    <% } %>
    <% if (order.status === "CANCELLED" && order.cancellationReason) { %>
      <div class="alert alert-danger border-0 small mb-4"><strong>Motif d’annulation :</strong> <%= order.cancellationReason %></div>
    <% } %>

    <h2 class="h6 mb-3">Lignes de commande</h2>
    <div class="card border-0 shadow-sm mb-4">
      <div class="table-responsive">
        <table class="table align-middle mb-0">
          <thead class="table-light small">
            <tr>
              <th>Réf.</th>
              <th>Produit</th>
              <th class="text-end">Qté</th>
              <th class="text-end">PU HT</th>
              <th class="text-center">TVA</th>
              <th class="text-end">Total TTC</th>
            </tr>
          </thead>
          <tbody>
            <% order.lines.forEach(function(l) { %>
              <tr>
                <td class="small font-monospace text-muted"><%= l.productSkuSnapshot %></td>
                <td><%= l.productNameSnapshot %></td>
                <td class="text-end"><%= l.quantity %></td>
                <td class="text-end"><%= Number(l.unitPriceHt).toFixed(2) %> €</td>
                <td class="text-center"><%= l.vatRate %>%</td>
                <td class="text-end fw-medium"><%= Number(l.lineTotalTtc).toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, "\u202f") %> €</td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
      <div class="card-footer bg-white d-flex justify-content-end gap-4 small">
        <span>Total HT <strong class="ms-1"><%= Number(order.totalHt).toFixed(2) %> €</strong></span>
        <span>TVA <strong class="ms-1"><%= Number(order.totalTva).toFixed(2) %> €</strong></span>
        <span>Total TTC <strong class="ms-1 fs-6"><%= Number(order.totalTtc).toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, "\u202f") %> €</strong></span>
      </div>
    </div>

    <a href="/portal/commandes" class="btn btn-outline-primary">← Retour à l’historique</a>
  </div>
</body>
</html>
