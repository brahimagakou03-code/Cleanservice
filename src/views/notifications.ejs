<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Notifications</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/public/styles/app.css" rel="stylesheet">
</head>
<body class="bg-light">
<%- include("partials/dashboard-header") %>
<div class="container py-4">
  <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <h1 class="h3 cs-page-title mb-0">Historique des notifications</h1>
    <form method="POST" action="/dashboard/notifications/read-all" class="m-0">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button type="submit" class="btn btn-outline-primary btn-sm">Tout marquer comme lu</button>
    </form>
  </div>

  <% if (!notifications || !notifications.length) { %>
    <p class="text-muted text-center py-5 mb-0">Aucune notification pour l’instant.</p>
  <% } else { %>
    <div class="d-flex flex-column gap-3">
      <% notifications.forEach(function(n){ %>
        <div class="card cs-tool-card <%= n.isRead ? '' : 'border-start border-primary border-4' %>">
          <div class="card-body py-3 px-4">
            <div class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-2">
              <strong class="text-dark"><%= n.title %></strong>
              <time class="small text-muted text-nowrap" datetime="<%= n.createdAt.toISOString() %>">
                <%= new Date(n.createdAt).toLocaleString("fr-FR") %>
              </time>
            </div>
            <p class="mb-3 small text-body-secondary"><%= n.message %></p>
            <div class="cs-action-group">
              <% if (n.link) { %>
                <a class="cs-btn-action" href="<%= n.link %>">Ouvrir</a>
              <% } %>
              <% if (!n.isRead) { %>
                <form method="POST" action="/dashboard/notifications/<%= n.id %>/read" class="d-inline m-0">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button type="submit" class="cs-btn-action">Marquer comme lu</button>
                </form>
              <% } %>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>

  <p class="mt-4 mb-0"><a class="btn btn-outline-secondary" href="/dashboard">← Retour au tableau de bord</a></p>
</div>
</body>
</html>
