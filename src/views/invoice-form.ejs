<!doctype html>
<html lang="fr"><head><meta charset="UTF-8"><title>Facture</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"><link href="/public/styles/app.css" rel="stylesheet"></head>
<body class="bg-light"><%- include("partials/dashboard-header") %><div class="container py-4">
  <h1 class="h3">Facture <%= invoice?.number || "(brouillon)" %></h1>
  <% if (!invoice) { %>
    <form id="createFromOrderForm" method="POST" action="/dashboard/invoices/from-order" class="card p-3">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="row g-2">
        <div class="col-md-4"><label>Client</label><select id="customerId" class="form-select" name="customerId" required><option value="">Sélectionner...</option><% customers.forEach(function(c){ %><option value="<%= c.id %>"><%= c.companyName %></option><% }) %></select></div>
        <div class="col-md-8"><label>Commande validée</label><select id="orderId" class="form-select" name="orderId" required><option value="">Sélectionner une commande...</option></select></div>
      </div>
      <p class="small text-muted mt-2 mb-0">Flux simplifié : choisissez le client puis sa commande validée. La facture de suivi est créée automatiquement à partir des lignes de commande.</p>
      <button class="btn btn-primary mt-3">Créer le suivi facture</button>
    </form>
    <script>
      const customers = <%- JSON.stringify((customers || []).map((c) => ({ id: c.id }))) %>;
      const eligibleOrders = <%- JSON.stringify(eligibleOrders || []) %>;
      const customerSelect = document.getElementById("customerId");
      const orderSelect = document.getElementById("orderId");
      function formatDate(isoDate) {
        const d = new Date(isoDate);
        return `${String(d.getDate()).padStart(2, "0")}/${String(d.getMonth() + 1).padStart(2, "0")}/${d.getFullYear()}`;
      }
      function loadOrders() {
        const selected = customers.find((c) => c.id === customerSelect.value);
        orderSelect.innerHTML = '<option value="">Sélectionner une commande...</option>';
        if (!selected) return;
        eligibleOrders.filter((o) => o.customerId === selected.id).forEach((o) => {
          const opt = document.createElement("option");
          opt.value = o.id;
          opt.textContent = `${o.number} - ${o.status} - ${Number(o.totalTtc || 0).toFixed(2)} EUR - ${formatDate(o.createdAt)}`;
          orderSelect.appendChild(opt);
        });
      }
      customerSelect.addEventListener("change", loadOrders);
      document.getElementById("createFromOrderForm").addEventListener("submit", function (e) {
        if (!orderSelect.value) return;
        this.action = `/dashboard/invoices/from-order/${orderSelect.value}`;
      });
    </script>
  <% } else { %>
    <div class="card p-3 mb-3">
      <% if (invoice.status === "DRAFT") { %>
        <form method="POST" action="/dashboard/invoices/<%= invoice.id %>/update" class="mb-3 border rounded p-3 bg-light">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <h2 class="h6">Modifier le brouillon</h2>
          <div class="row g-2">
            <div class="col-md-4"><label>Client</label><select id="editCustomerId" class="form-select" name="customerId" required><% customers.forEach(function(c){ %><option value="<%= c.id %>" <%= c.id===invoice.customerId?'selected':'' %>><%= c.companyName %></option><% }) %></select></div>
            <div class="col-md-5"><label>Site</label><select id="editCustomerSiteId" class="form-select" name="customerSiteId"></select></div>
            <div class="col-md-3"><label>Type</label><select class="form-select" name="type"><option value="INVOICE" <%= invoice.type==="INVOICE"?'selected':'' %>>Facture</option><option value="PROFORMA" <%= invoice.type==="PROFORMA"?'selected':'' %>>Proforma</option><option value="CREDIT_NOTE" <%= invoice.type==="CREDIT_NOTE"?'selected':'' %>>Avoir</option></select></div>
          </div>
          <textarea class="form-control mt-2" name="notes" placeholder="Notes"><%= invoice.notes || "" %></textarea>
          <button class="btn btn-outline-primary mt-2">Enregistrer les modifications</button>
        </form>
      <% } %>
      <p>Client: <strong><%= invoice.customer.companyName %></strong></p>
      <p>Site: <strong><%= invoiceSite?.label || "-" %></strong> <% if (invoiceSite?.fullAddress) { %> - <%= invoiceSite.fullAddress %><% } %></p>
      <p>Statut: <strong><%= fr.invoiceStatus(invoice.status) %></strong> | Type: <strong><%= fr.invoiceType(invoice.type) %></strong></p>
      <p>Émission : <%= invoice.issuedAt ? invoice.issuedAt.toISOString().slice(0,10) : "-" %> | Échéance : <%= invoice.dueAt ? invoice.dueAt.toISOString().slice(0,10) : "-" %></p>
      <p>Total HT: <%= invoice.totalHt %> | TVA: <%= invoice.totalTva %> | TTC: <%= invoice.totalTtc %></p>
      <p>Payé : <%= invoice.amountPaid %> | Reste : <%= invoice.amountDue %></p>
      <h2 class="h5">Lignes</h2>
      <table class="table table-sm"><thead><tr><th>Description</th><th>Qte</th><th>PU HT</th><th>TVA</th><th>Remise</th><th>Total TTC</th></tr></thead><tbody><% invoice.lines.forEach(function(l){ %><tr><td><%= l.description %></td><td><%= l.quantity %></td><td><%= l.unitPriceHt %></td><td><%= l.vatRate %>%</td><td><%= l.discountPercent %>%</td><td><%= l.lineTotalTtc %></td></tr><% }) %></tbody></table>
      <% if (invoice.pdfUrl) { %>
        <h2 class="h5">Aperçu PDF</h2>
        <iframe src="<%= invoice.pdfUrl %>" style="width:100%;height:500px;border:1px solid #ddd;"></iframe>
      <% } %>
      <div class="d-flex flex-wrap gap-2 mt-2">
        <% if (invoice.status === "DRAFT") { %>
          <form method="POST" action="/dashboard/invoices/<%= invoice.id %>/finalize"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="btn btn-primary">Finaliser (verrouiller)</button></form>
          <form method="POST" action="/dashboard/invoices/<%= invoice.id %>/delete"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="btn btn-outline-danger">Supprimer brouillon</button></form>
        <% } %>
        <% if (["SENT","PARTIALLY_PAID","OVERDUE"].includes(invoice.status)) { %>
          <form method="POST" action="/dashboard/invoices/<%= invoice.id %>/payment" class="d-flex flex-wrap gap-1 align-items-end">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div>
              <label class="form-label small mb-0">Montant <span class="text-danger" aria-hidden="true">*</span></label>
              <input class="form-control" name="amount" placeholder="0,00" value="<%= Number(invoice.amountDue || 0) > 0 ? Number(invoice.amountDue).toFixed(2) : '' %>" required>
            </div>
            <input class="form-control" type="date" name="paidAt">
            <select class="form-select" name="method"><% paymentMethods.forEach(function(m){ %><option value="<%= m %>"><%= m %></option><% }) %></select>
            <input class="form-control" name="reference" placeholder="Référence">
            <button class="btn btn-success">Valider comme payé / Ajouter paiement</button>
          </form>
          <form method="POST" action="/dashboard/invoices/<%= invoice.id %>/create-credit-note"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="btn btn-warning">Générer un avoir</button></form>
          <form method="POST" action="/dashboard/invoices/<%= invoice.id %>/send-email"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="btn btn-outline-primary">Envoyer l’e-mail</button></form>
        <% } %>
        <% if (invoice.pdfUrl) { %><a class="btn btn-outline-dark" href="/dashboard/invoices/<%= invoice.id %>/pdf">Télécharger le PDF</a><% } %>
      </div>
      <h2 class="h5 mt-3">Paiements reçus</h2>
      <table class="table table-sm"><thead><tr><th>Date</th><th>Montant</th><th>Méthode</th><th>Référence</th><th>Notes</th></tr></thead><tbody><% invoice.payments.forEach(function(p){ %><tr><td><%= p.paidAt.toISOString().slice(0,10) %></td><td><%= p.amount %></td><td><%= p.method %></td><td><%= p.reference || "-" %></td><td><%= p.notes || "-" %></td></tr><% }) %></tbody></table>
    </div>
    <script>
      const customers = <%- JSON.stringify((customers || []).map((c) => ({ id: c.id, sites: c.sites || [] }))) %>;
      const selectedSiteId = <%- JSON.stringify(invoiceSite?.id || "") %>;
      const customerSelect = document.getElementById("editCustomerId");
      const siteSelect = document.getElementById("editCustomerSiteId");
      if (customerSelect && siteSelect) {
        function loadSites() {
          const selected = customers.find((c) => c.id === customerSelect.value);
          siteSelect.innerHTML = '<option value="">Sélectionner un site...</option>';
          if (!selected) return;
          selected.sites.forEach((s) => {
            const opt = document.createElement("option");
            opt.value = s.id;
            opt.textContent = `${s.label} - ${s.fullAddress}`;
            if (s.id === selectedSiteId) opt.selected = true;
            siteSelect.appendChild(opt);
          });
        }
        customerSelect.addEventListener("change", loadSites);
        loadSites();
      }
    </script>
  <% } %>
  <p><a class="btn btn-outline-secondary" href="/dashboard/invoices">Retour</a></p>
</div></body></html>
