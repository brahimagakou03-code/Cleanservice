<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Connexion portail client</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/public/styles/app.css" rel="stylesheet">
</head>
<body class="bg-light">
  <%- include("partials/auth-header", { mode: "portal" }) %>
  <div class="container py-5" style="max-width:560px;">
    <div class="text-center mb-4">
      <img src="/branding/logo.png" class="cs-logo-hero" alt="Clean Service">
      <h1 class="h4 mt-4">Portail client</h1>
      <p class="cs-subtle">Utilisez l’e-mail enregistré chez votre fournisseur et le <strong>mot de passe</strong> reçu par e-mail, ou bien le <strong>code client</strong> (ex. CLI-0001) si vous préférez ne pas saisir le mot de passe.</p>
      <p class="small text-muted mb-0"><span class="text-danger" aria-hidden="true">*</span> Champ obligatoire (e-mail)</p>
    </div>
    <% if (typeof loginError !== "undefined" && loginError) { %>
      <div class="alert alert-danger" role="alert"><%= loginError %></div>
    <% } %>
    <form method="POST" action="/portal/login" class="card p-3">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <label class="form-label" for="pl-email">E-mail (identifiant) <span class="text-danger" aria-hidden="true">*</span></label>
      <input id="pl-email" class="form-control" type="email" name="email" required autocomplete="username">
      <label class="form-label mt-3" for="pl-password">Mot de passe</label>
      <input id="pl-password" class="form-control" type="password" name="password" autocomplete="current-password">
      <details class="mt-3 small cs-subtle">
        <summary class="cursor-pointer">Code client (alternative au mot de passe)</summary>
        <p class="mt-2 mb-2">Vous pouvez laisser le mot de passe vide et saisir uniquement votre <strong>code client</strong> (valable même si un mot de passe a déjà été défini).</p>
        <label class="form-label" for="pl-code">Code client</label>
        <input id="pl-code" class="form-control" type="text" name="code" placeholder="CLI-0001" autocomplete="off">
      </details>
      <button class="btn btn-primary mt-4 w-100" type="submit">Se connecter</button>
    </form>
    <p class="mt-3"><a class="btn btn-outline-secondary" href="/">Retour</a></p>
  </div>
</body>
</html>
