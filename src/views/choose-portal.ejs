<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Accès plateforme</title>
  <%- include("partials/favicon") %>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/public/styles/app.css" rel="stylesheet">
</head>
<body class="bg-light">
  <%- include("partials/auth-header", { mode: "chooser" }) %>
  <div class="container py-5">
    <div class="text-center mb-5">
      <img src="<%= typeof platformLogoUrl !== 'undefined' ? platformLogoUrl : '/branding/logo.png' %>" alt="Clean Service" class="cs-logo-hero">
      <h1 class="h3 mt-4">Choisissez votre portail</h1>
      <p class="cs-subtle">Accédez à votre espace selon votre profil.</p>
    </div>
    <div class="row g-4 justify-content-center">
      <div class="col-md-4">
        <div class="card p-4 text-center h-100">
          <h2 class="h5">Administrateur</h2>
          <a class="btn btn-primary mt-2" href="/login">Entrer en administration</a>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card p-4 text-center h-100">
          <h2 class="h5">Portail Client</h2>
          <a class="btn btn-outline-primary mt-2" href="/portal/login">Entrer en espace client</a>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
