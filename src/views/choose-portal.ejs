<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Accès plateforme</title>
  <%- include("partials/favicon") %>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/public/styles/app.css" rel="stylesheet">
</head>
<body class="bg-light">
  <%- include("partials/auth-header", { mode: "chooser" }) %>
  <div class="container py-5">
    <div class="text-center mb-5">
      <img src="<%= typeof platformLogoUrl !== 'undefined' ? platformLogoUrl : '/branding/logo.png' %>" alt="Clean Service" class="cs-logo-hero">
      <h1 class="h3 mt-4">Choisir votre portail</h1>
      <p class="cs-subtle">Chaque URL ouvre un portail dédié avec contrôle des droits.</p>
    </div>
    <div class="row g-4 justify-content-center">
      <div class="col-md-5">
        <div class="card p-4 text-center h-100">
          <h2 class="h5">Admin boutique</h2>
          <p class="small text-muted mb-3">Portail du propriétaire de boutique (dashboard, produits, commandes, stats).</p>
          <a class="btn btn-primary mt-2" href="/admin/login">Accès admin</a>
        </div>
      </div>
      <div class="col-md-5">
        <div class="card p-4 text-center h-100">
          <h2 class="h5">Client</h2>
          <p class="small text-muted mb-3">Portail commandes client, réservé aux comptes client actifs.</p>
          <a class="btn btn-outline-primary mt-2" href="/portal/login">Accès client</a>
          <a class="btn btn-outline-secondary mt-2" href="/admin-test">Tester une connexion admin</a>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
