<!doctype html>
<html lang="fr">
  <head><meta charset="UTF-8"><title>Connexion</title><%- include("partials/favicon") %><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"><link href="/public/styles/app.css" rel="stylesheet"></head>
  <body class="bg-light">
    <%- include("partials/auth-header", { mode: "staff" }) %>
    <div class="container py-5" style="max-width:540px;">
    <div class="text-center mb-4"><img src="<%= typeof platformLogoUrl !== 'undefined' ? platformLogoUrl : '/branding/logo.png' %>" class="cs-logo-hero" alt="Clean Service"></div>
    <h1 class="h3 text-center mb-3">Connexion</h1>
    <p class="small text-muted text-center mb-3">Un seul compte (Supabase) pour l’administration et le portail client : vous serez redirigé selon votre profil.</p>
    <% if (typeof fromPortal !== "undefined" && fromPortal) { %>
    <div class="alert alert-info mb-3" role="alert">Vous accédez au portail client : après connexion, vous serez envoyé vers votre espace commandes.</div>
    <% } %>
    <% if (typeof loginAlert !== "undefined" && loginAlert) { %>
    <div class="alert alert-warning mb-3" role="alert"><%= loginAlert %></div>
    <% } %>
    <p class="small text-muted text-center mb-2"><span class="text-danger" aria-hidden="true">*</span> E-mail obligatoire ; mot de passe <strong>ou</strong> code client si applicable.</p>
    <form method="POST" action="/login" class="card p-3">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <label class="form-label">E-mail <span class="text-danger" aria-hidden="true">*</span><input class="form-control" type="email" name="email" autocomplete="username" required /></label><br />
      <label class="form-label">Mot de passe<input class="form-control" type="password" name="password" autocomplete="current-password" /></label><br />
      <label class="form-label">Code client (optionnel)<input class="form-control" type="text" name="code" autocomplete="off" placeholder="ex. CLI-0001 si votre fournisseur vous l’a indiqué" /></label><br />
      <button class="btn btn-primary" type="submit">Se connecter</button>
    </form>
    <p class="text-center mt-3 mb-1"><a href="/register">Créer un compte (équipe)</a></p>
    <p class="text-center small"><a href="/admin-test">Page de test connexion admin</a></p>
    </div>
  </body>
</html>
