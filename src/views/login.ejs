<!doctype html>
<html lang="fr">
  <head><meta charset="UTF-8"><title>Connexion</title><%- include("partials/favicon") %><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"><link href="/public/styles/app.css" rel="stylesheet"></head>
  <body class="bg-light">
    <%- include("partials/auth-header", { mode: "staff" }) %>
    <div class="container py-5" style="max-width:540px;">
    <div class="text-center mb-4"><img src="<%= typeof platformLogoUrl !== 'undefined' ? platformLogoUrl : '/branding/logo.png' %>" class="cs-logo-hero" alt="Clean Service"></div>
    <h1 class="h3 text-center mb-3">Connexion</h1>
    <p class="small text-muted text-center mb-2"><span class="text-danger" aria-hidden="true">*</span> Champ obligatoire</p>
    <form method="POST" action="/login" class="card p-3">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <label class="form-label">E-mail <span class="text-danger" aria-hidden="true">*</span><input class="form-control" type="email" name="email" required /></label><br />
      <label class="form-label">Mot de passe <span class="text-danger" aria-hidden="true">*</span><input class="form-control" type="password" name="password" required /></label><br />
      <button class="btn btn-primary" type="submit">Se connecter</button>
    </form>
    <p class="text-center mt-3"><a href="/register">Créer un compte</a></p>
    </div>
  </body>
</html>
