<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Catalogue</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/public/styles/app.css" rel="stylesheet">
</head>
<body class="bg-light">
<%- include("partials/dashboard-header") %>
<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Catalogue</h1>
    <div class="btn-group">
      <a class="btn btn-outline-secondary" href="/dashboard">Tableau de bord</a>
      <a class="btn btn-primary" href="/dashboard/catalog/new">Nouveau produit</a>
      <a class="btn btn-outline-primary" href="/dashboard/catalog/categories/manage">Catégories</a>
      <a class="btn btn-outline-primary" href="/dashboard/catalog/import">Importer CSV</a>
      <a class="btn btn-outline-success" href="/dashboard/catalog/export/csv">Exporter CSV</a>
    </div>
  </div>

  <form id="catalogFiltersForm" class="row g-2 mb-3" method="GET" action="/dashboard/catalog">
    <input type="hidden" name="page" value="1">
    <div class="col-md-2"><input class="form-control" name="q" value="<%= filters.q %>" placeholder="Nom, référence ou description"></div>
    <div class="col-md-2">
      <select class="form-select" name="categoryId">
        <option value="">Toutes catégories</option>
        <% categories.forEach(function(c){ %>
          <option value="<%= c.id %>" <%= filters.categoryId===c.id?"selected":"" %>><%= "-".repeat(c.depth) %> <%= c.name %></option>
        <% }) %>
      </select>
    </div>
    <div class="col-md-1"><input class="form-control" name="minPrice" value="<%= filters.minPrice %>" placeholder="Prix min"></div>
    <div class="col-md-1"><input class="form-control" name="maxPrice" value="<%= filters.maxPrice %>" placeholder="Prix max"></div>
    <div class="col-md-1">
      <select class="form-select" name="status"><option value="">Statut</option><option value="active" <%= filters.status==='active'?'selected':'' %>>Actif</option><option value="inactive" <%= filters.status==='inactive'?'selected':'' %>>Inactif</option></select>
    </div>
    <div class="col-md-1">
      <select class="form-select" name="sortBy"><option value="createdAt">Date</option><option value="name" <%= filters.sortBy==='name'?'selected':'' %>>Nom</option><option value="basePriceHt" <%= filters.sortBy==='basePriceHt'?'selected':'' %>>Prix</option><option value="stockQty" <%= filters.sortBy==='stockQty'?'selected':'' %>>Stock</option></select>
    </div>
      <div class="col-md-1">
        <select class="form-select" name="sortDir"><option value="asc" <%= filters.sortDir==='asc'?'selected':'' %>>Croissant</option><option value="desc" <%= filters.sortDir==='desc'?'selected':'' %>>Décroissant</option></select>
      </div>
    <div class="col-md-1">
      <select class="form-select" name="view"><option value="grid" <%= view==='grid'?'selected':'' %>>Grille</option><option value="list" <%= view==='list'?'selected':'' %>>Liste</option></select>
    </div>
    <div class="col-md-1">
      <select class="form-select" name="perPage" title="Produits par page">
        <% (typeof catalogPageSizes !== "undefined" ? catalogPageSizes : [25,50,100,250]).forEach(function(n){ %>
          <option value="<%= n %>" <%= (typeof pageSize !== "undefined" ? pageSize : 100) === n ? "selected" : "" %>><%= n %>/p.</option>
        <% }) %>
      </select>
    </div>
    <div class="col-md-1"><button type="submit" class="btn btn-dark w-100">Filtrer</button></div>
  </form>

  <% if (typeof totalCount !== "undefined" && totalCount > 0 && typeof rangeFrom !== "undefined") { %>
    <p class="small text-muted mb-2">Affichage <strong><%= rangeFrom %>–<%= rangeTo %></strong> sur <strong><%= totalCount %></strong> produit<%= totalCount > 1 ? "s" : "" %>. Utilisez <em>Précédent</em> / <em>Suivant</em> ou augmentez «&nbsp;100/p.&nbsp;» pour voir la suite sur une seule page.</p>
  <% } %>

  <% if (typeof totalCount !== "undefined" && totalCount === 0) { %>
    <div class="alert alert-warning border">
      <strong>Catalogue vide pour votre organisation.</strong>
      Les produits sont liés à <em>votre</em> espace (multi-tenant). Si vous venez d’importer le référentiel CLEAN SERVICES,
      il a peut‑être été chargé sur une <em>autre</em> organisation de la base de démo.
      Rechargez le catalogue pour <strong>votre</strong> compte avec&nbsp;:
      <code class="d-block mt-2 small">set CLEAN_SERVICES_USER_EMAIL=votre@email.com &amp;&amp; npm run catalog:reset-clean</code>
      <span class="d-block small mt-1">(PowerShell&nbsp;: <code>$env:CLEAN_SERVICES_USER_EMAIL="..."; npm run catalog:reset-clean</code>)</span>
      Ou créez des produits avec le bouton <strong>Nouveau produit</strong> ci‑dessus.
    </div>
  <% } %>

  <% if (view === "list") { %>
    <table class="table table-striped bg-white">
      <thead><tr><th>Réf.</th><th>Nom</th><th>Catégorie</th><th>Prix HT</th><th>Prix TTC</th><th>TVA</th><th>Stock</th><th>Actif</th><th>Rupture client</th></tr></thead>
      <tbody>
      <% products.forEach(function(p){ %>
        <tr>
          <td><a href="/dashboard/catalog/<%= p.id %>"><%= p.sku %></a></td>
          <td><%= p.name %></td><td><%= p.category?.name || "-" %></td>
          <td class="text-nowrap"><%= formatEuroHtDisplay(p.basePriceHt) %> €</td>
          <td class="text-nowrap"><%= formatEuroTtcDisplay(p.basePriceHt, p.vatRate) %> €</td>
          <td><%= p.vatRate %>%</td>
          <td><%= p.stockQty ?? "N/A" %></td><td><%= p.isActive ? "Oui":"Non" %></td><td><%= p.portalRuptureStock ? "Oui":"Non" %></td>
        </tr>
      <% }) %>
      </tbody>
    </table>
  <% } else { %>
    <div class="row g-3">
      <% products.forEach(function(p){ const imgs = (p.imageUrls || "").split("|").filter(Boolean); %>
        <div class="col-md-3">
          <div class="card h-100 position-relative shadow-sm">
            <% if (imgs[0]) { %><img src="<%= imgs[0] %>" class="card-img-top" style="height:160px;object-fit:cover"><% } %>
            <div class="card-body pb-5">
              <div class="small text-muted"><%= p.sku %></div>
              <h5 class="card-title"><a href="/dashboard/catalog/<%= p.id %>"><%= p.name %></a></h5>
              <div class="small"><span class="fw-semibold"><%= formatEuroHtDisplay(p.basePriceHt) %> € HT</span>
                <span class="text-muted"> · <%= formatEuroTtcDisplay(p.basePriceHt, p.vatRate) %> € TTC</span>
                <span class="text-muted"> (TVA <%= p.vatRate %>%)</span></div>
            </div>
            <div class="position-absolute bottom-0 end-0 m-2 d-flex flex-column align-items-end gap-1">
              <% if (p.portalRuptureStock) { %><span class="badge rounded-pill small shadow-sm text-bg-warning text-dark" title="Affiché en rupture sur le portail client">Rupture portail</span><% } %>
              <span class="badge rounded-pill small shadow-sm <%= p.isActive ? 'text-bg-success' : 'text-bg-danger' %>" title="<%= p.isActive ? 'Produit actif' : 'Produit inactif' %>"><%= p.isActive ? 'Actif' : 'Inactif' %></span>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>

  <div class="mt-3 d-flex gap-2 align-items-center flex-wrap">
    <span>Page <%= page %> / <%= totalPages %></span>
    <% var _pp = typeof pageSize !== "undefined" ? pageSize : 100; %>
    <% if (page > 1) { %><a class="btn btn-sm btn-outline-dark" href="?page=<%= page-1 %>&q=<%= encodeURIComponent(filters.q) %>&categoryId=<%= filters.categoryId %>&status=<%= filters.status %>&minPrice=<%= filters.minPrice %>&maxPrice=<%= filters.maxPrice %>&sortBy=<%= filters.sortBy %>&sortDir=<%= filters.sortDir %>&view=<%= view %>&perPage=<%= _pp %>">Précédent</a><% } %>
    <% if (page < totalPages) { %><a class="btn btn-sm btn-outline-dark" href="?page=<%= page+1 %>&q=<%= encodeURIComponent(filters.q) %>&categoryId=<%= filters.categoryId %>&status=<%= filters.status %>&minPrice=<%= filters.minPrice %>&maxPrice=<%= filters.maxPrice %>&sortBy=<%= filters.sortBy %>&sortDir=<%= filters.sortDir %>&view=<%= view %>&perPage=<%= _pp %>">Suivant</a><% } %>
  </div>
</div>
<script>
  (function () {
    var form = document.getElementById("catalogFiltersForm");
    if (!form) return;
    var controls = form.querySelectorAll("select");
    controls.forEach(function (el) {
      el.addEventListener("change", function () { form.requestSubmit(); });
    });
  })();
</script>
</body>
</html>
