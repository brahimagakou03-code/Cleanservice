<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Inscription admin magasin</title>
  <%- include("partials/favicon") %>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/public/styles/app.css" rel="stylesheet">
</head>
<body class="bg-light">
  <%- include("partials/auth-header", { mode: "portal" }) %>
  <div class="container py-5" style="max-width:760px;">
    <div class="text-center mb-4">
      <img src="<%= typeof platformLogoUrl !== 'undefined' ? platformLogoUrl : '/branding/logo.png' %>" class="cs-logo-hero" alt="Clean Service">
      <h1 class="h4 mt-4">Inscription administrateur magasin</h1>
      <p class="cs-subtle">Creation d'un compte administrateur avec verification OTP par e-mail.</p>
    </div>

    <% if (error) { %>
      <div class="alert alert-danger" role="alert"><%= error %></div>
    <% } %>
    <% if (success) { %>
      <div class="alert alert-success" role="alert"><%= success %></div>
    <% } %>

    <form method="POST" action="/portal/register-admin/request-otp" class="card p-3 mb-3">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <p class="small text-muted mb-2"><span class="text-danger" aria-hidden="true">*</span> Champ obligatoire</p>
      <div class="row g-3">
        <div class="col-md-6">
          <label class="form-label" for="orgName">Nom magasin <span class="text-danger">*</span></label>
          <input id="orgName" class="form-control" name="orgName" required value="<%= formData.orgName || '' %>">
        </div>
        <div class="col-md-6">
          <label class="form-label" for="slug">Slug <span class="text-danger">*</span></label>
          <input id="slug" class="form-control" name="slug" required value="<%= formData.slug || '' %>" placeholder="mon-magasin">
        </div>
        <div class="col-md-6">
          <label class="form-label" for="siret">SIRET <span class="text-danger">*</span></label>
          <input id="siret" class="form-control" name="siret" required value="<%= formData.siret || '' %>">
        </div>
        <div class="col-md-6">
          <label class="form-label" for="orgEmail">E-mail magasin <span class="text-danger">*</span></label>
          <input id="orgEmail" class="form-control" type="email" name="orgEmail" required value="<%= formData.orgEmail || '' %>">
        </div>
        <div class="col-12">
          <label class="form-label" for="address">Adresse <span class="text-danger">*</span></label>
          <input id="address" class="form-control" name="address" required value="<%= formData.address || '' %>">
        </div>
        <div class="col-md-6">
          <label class="form-label" for="phone">Telephone <span class="text-danger">*</span></label>
          <input id="phone" class="form-control" name="phone" required value="<%= formData.phone || '' %>">
        </div>
        <div class="col-md-6">
          <label class="form-label" for="email">E-mail administrateur <span class="text-danger">*</span></label>
          <input id="email" class="form-control" type="email" name="email" required value="<%= formData.email || '' %>">
        </div>
        <div class="col-md-6">
          <label class="form-label" for="firstName">Prenom <span class="text-danger">*</span></label>
          <input id="firstName" class="form-control" name="firstName" required value="<%= formData.firstName || '' %>">
        </div>
        <div class="col-md-6">
          <label class="form-label" for="lastName">Nom <span class="text-danger">*</span></label>
          <input id="lastName" class="form-control" name="lastName" required value="<%= formData.lastName || '' %>">
        </div>
      </div>
      <button class="btn btn-primary mt-4" type="submit">Envoyer le code OTP</button>
    </form>

    <% if (otpStep) { %>
      <form method="POST" action="/portal/register-admin/verify-otp" class="card p-3">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <input type="hidden" name="signupId" value="<%= signupId %>">
        <label class="form-label" for="otp">Code OTP recu par e-mail</label>
        <input id="otp" class="form-control" name="otp" inputmode="numeric" maxlength="6" minlength="6" placeholder="123456" required>
        <button class="btn btn-success mt-3" type="submit">Verifier et creer le compte admin</button>
      </form>
    <% } %>

    <p class="mt-3">
      <a class="btn btn-outline-secondary" href="/portal/login">Retour connexion portail</a>
    </p>
  </div>
</body>
</html>
