<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Importation CSV clients</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/public/styles/app.css" rel="stylesheet">
</head>
<body class="bg-light">
<%- include("partials/dashboard-header") %>
<div class="container py-4">
  <h1 class="h3 cs-page-title mb-4">Importation CSV clients</h1>

  <div class="card cs-tool-card mb-4">
    <div class="card-header">1) Charger le fichier</div>
    <div class="card-body">
      <form method="POST" action="/dashboard/customers/import/preview" enctype="multipart/form-data">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <label class="form-label fw-semibold small">Fichier CSV <span class="text-danger">*</span></label>
        <input class="form-control mb-3" type="file" name="file" accept=".csv,text/csv" required />
        <button type="submit" class="btn btn-primary">Prévisualiser</button>
      </form>
    </div>
  </div>

  <% if (report) { %>
    <div class="alert <%= report.failed ? 'alert-warning' : 'alert-success' %> border-0 shadow-sm mb-4">
      Import terminé : <strong><%= report.imported %></strong> importés, <strong><%= report.failed %></strong> échoués.
    </div>
    <% if (report.errors && report.errors.length) { %>
      <div class="card cs-tool-card mb-4">
        <div class="card-header text-danger">Erreurs</div>
        <div class="card-body">
          <ul class="mb-0 small">
            <% report.errors.forEach(function(e){ %><li>Ligne <%= e.row %> — <%= e.message %></li><% }) %>
          </ul>
        </div>
      </div>
    <% } %>
  <% } %>

  <% if (rows && rows.length) { %>
    <div class="card cs-tool-card mb-4">
      <div class="card-header">2) Correspondance des colonnes</div>
      <div class="card-body">
        <form method="POST" action="/dashboard/customers/import/commit">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <input type="hidden" name="previewData" value='<%= preview %>' />
          <div class="row g-3">
            <div class="col-md-4">
              <label class="form-label small fw-semibold">Entreprise</label>
              <select class="form-select" name="mapCompanyName">
                <% headers.forEach(function(h){ %><option value="<%= h %>"><%= h %></option><% }) %>
              </select>
            </div>
            <div class="col-md-4">
              <label class="form-label small fw-semibold">E-mail</label>
              <select class="form-select" name="mapEmail">
                <option value="">(vide)</option>
                <% headers.forEach(function(h){ %><option value="<%= h %>"><%= h %></option><% }) %>
              </select>
            </div>
            <div class="col-md-4">
              <label class="form-label small fw-semibold">Téléphone</label>
              <select class="form-select" name="mapPhone">
                <option value="">(vide)</option>
                <% headers.forEach(function(h){ %><option value="<%= h %>"><%= h %></option><% }) %>
              </select>
            </div>
            <div class="col-md-4">
              <label class="form-label small fw-semibold">Pays</label>
              <select class="form-select" name="mapCountryCode">
                <option value="">(FR)</option>
                <% headers.forEach(function(h){ %><option value="<%= h %>"><%= h %></option><% }) %>
              </select>
            </div>
            <div class="col-md-4">
              <label class="form-label small fw-semibold">SIRET</label>
              <select class="form-select" name="mapSiret">
                <option value="">(vide)</option>
                <% headers.forEach(function(h){ %><option value="<%= h %>"><%= h %></option><% }) %>
              </select>
            </div>
            <div class="col-md-4">
              <label class="form-label small fw-semibold">N° TVA</label>
              <select class="form-select" name="mapVatNumber">
                <option value="">(vide)</option>
                <% headers.forEach(function(h){ %><option value="<%= h %>"><%= h %></option><% }) %>
              </select>
            </div>
          </div>
          <button class="btn btn-success mt-4" type="submit">Importer</button>
        </form>
      </div>
    </div>

    <div class="card cs-tool-card">
      <div class="card-header">Prévisualisation (10 lignes max)</div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-sm table-hover align-middle mb-0">
            <thead class="table-light">
              <tr>
                <% headers.forEach(function(h){ %><th class="small text-uppercase text-muted"><%= h %></th><% }) %>
              </tr>
            </thead>
            <tbody>
              <% rows.forEach(function(r){ %>
                <tr>
                  <% headers.forEach(function(h){ %><td class="small"><%= r[h] %></td><% }) %>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  <% } %>

  <p class="mt-4 mb-0"><a class="btn btn-outline-secondary" href="/dashboard/customers">← Retour aux clients</a></p>
</div>
</body>
</html>
