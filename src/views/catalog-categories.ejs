<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Catégories du catalogue</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/public/styles/app.css" rel="stylesheet">
</head>
<body class="bg-light">
<%- include("partials/dashboard-header") %>
<div class="container py-4">
  <h1 class="h3 cs-page-title mb-4">Catégories (arborescence)</h1>

  <div class="card cs-tool-card mb-4">
    <div class="card-header">Nouvelle catégorie</div>
    <div class="card-body">
      <form method="POST" action="/dashboard/catalog/categories">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <div class="row g-3 align-items-end">
          <div class="col-md-3">
            <label class="form-label small fw-semibold text-muted mb-1">Nom <span class="text-danger" aria-hidden="true">*</span></label>
            <input class="form-control" name="name" placeholder="Ex. Entretien des sols" required>
          </div>
          <div class="col-md-2">
            <label class="form-label small fw-semibold text-muted mb-1">Slug <span class="small fw-normal">(optionnel)</span></label>
            <input class="form-control" name="slug" placeholder="auto si vide">
          </div>
          <div class="col-md-3">
            <label class="form-label small fw-semibold text-muted mb-1">Description</label>
            <input class="form-control" name="description" placeholder="Courte description">
          </div>
          <div class="col-md-2">
            <label class="form-label small fw-semibold text-muted mb-1">Parent</label>
            <select class="form-select" name="parentId">
              <option value="">Racine</option>
              <% categories.forEach(function(c){ %>
                <option value="<%= c.id %>"><%= "— ".repeat(c.depth) %><%= c.name %></option>
              <% }) %>
            </select>
          </div>
          <div class="col-md-1">
            <label class="form-label small fw-semibold text-muted mb-1">Ordre</label>
            <input class="form-control" type="number" name="sortOrder" value="0" title="Tri dans la liste">
          </div>
          <div class="col-md-1 d-grid">
            <label class="form-label small d-none d-md-block">&nbsp;</label>
            <button type="submit" class="btn btn-primary">Ajouter</button>
          </div>
        </div>
      </form>
    </div>
  </div>

  <div class="cs-hint-banner mb-3">
    <span class="cs-hint-icon" aria-hidden="true">↕</span>
    <div>
      <strong class="d-block mb-1">Réorganiser par glisser-déposer</strong>
      Saisissez l’icône <strong>⋮⋮</strong> à gauche, puis déposez la ligne <strong>sur une autre catégorie</strong> pour l’imbriquer sous celle-ci.
      Avec <kbd class="px-1">Maj</kbd> enfoncée, déposez dans la zone pointillée en bas pour <strong>remettre à la racine</strong>.
    </div>
  </div>

  <div class="card cs-tool-card">
    <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
      <span>Structure actuelle</span>
      <span class="small fw-normal text-muted"><%= categories.length %> catégorie<%= categories.length !== 1 ? "s" : "" %></span>
    </div>
    <div class="card-body p-3">
      <ul id="tree" class="cs-category-tree">
        <% categories.forEach(function(c){ %>
          <% var d = Math.min(Number(c.depth) || 0, 3); %>
          <li class="cs-category-row cs-category-depth-<%= d %>" draggable="true" data-id="<%= c.id %>">
            <span class="cs-drag-handle" title="Glisser pour réorganiser" aria-label="Glisser pour réorganiser">⋮⋮</span>
            <span class="cs-category-label"><% if (c.depth) { %><span class="text-muted fw-normal"><%= "— ".repeat(c.depth) %></span> <% } %><%= c.name %></span>
            <span class="cs-category-meta"><span class="badge bg-light text-secondary border">ordre <%= c.sortOrder %></span></span>
          </li>
        <% }) %>
      </ul>
      <% if (!categories.length) { %>
        <p class="text-muted small mb-0 text-center py-4">Aucune catégorie pour l’instant. Ajoutez-en une ci-dessus.</p>
      <% } %>
      <div id="dndRootZone" class="cs-dnd-root-zone mt-3 py-3 px-2 small text-muted text-center user-select-none">
        <span class="text-body-secondary">Zone racine</span> — relâchez ici avec <kbd class="px-1">Maj</kbd> pour détacher du parent
      </div>
    </div>
  </div>

  <div class="mt-4 d-flex flex-wrap gap-2">
    <a class="btn btn-outline-secondary" href="/dashboard/catalog">← Retour au catalogue</a>
  </div>
</div>
<script>
(function () {
  const list = document.getElementById("tree");
  const rootZone = document.getElementById("dndRootZone");
  if (!list) return;

  let dragId = null;
  let dragEl = null;

  function clearOver() {
    list.querySelectorAll(".cs-dnd-over").forEach((el) => el.classList.remove("cs-dnd-over"));
    rootZone && rootZone.classList.remove("cs-dnd-root-active");
  }

  function postReorder(body) {
    return fetch("/dashboard/catalog/categories/reorder", {
      method: "POST",
      headers: { "Content-Type": "application/json", "CSRF-Token": "<%= csrfToken %>" },
      body: JSON.stringify(body),
    });
  }

  list.querySelectorAll("li").forEach((li) => {
    li.addEventListener("dragstart", (e) => {
      dragId = li.dataset.id;
      dragEl = li;
      li.classList.add("cs-dnd-dragging");
      e.dataTransfer.effectAllowed = "move";
      e.dataTransfer.setData("text/plain", dragId);
    });
    li.addEventListener("dragend", () => {
      li.classList.remove("cs-dnd-dragging");
      clearOver();
      dragId = null;
      dragEl = null;
    });
    li.addEventListener("dragover", (e) => {
      e.preventDefault();
      e.dataTransfer.dropEffect = "move";
    });
    li.addEventListener("dragenter", (e) => {
      if (!dragEl || dragEl === li) return;
      li.classList.add("cs-dnd-over");
    });
    li.addEventListener("dragleave", (e) => {
      if (!li.contains(e.relatedTarget)) li.classList.remove("cs-dnd-over");
    });
    li.addEventListener("drop", async (e) => {
      e.preventDefault();
      clearOver();
      const targetId = li.dataset.id;
      if (!dragId || dragId === targetId) return;
      await postReorder({ id: dragId, newParentId: targetId, newSortOrder: 0 });
      location.reload();
    });
  });

  document.addEventListener("dragover", (e) => {
    e.preventDefault();
    if (rootZone && dragId && e.shiftKey) rootZone.classList.add("cs-dnd-root-active");
    else if (rootZone) rootZone.classList.remove("cs-dnd-root-active");
  });

  if (rootZone) {
    rootZone.addEventListener("dragleave", (e) => {
      if (!rootZone.contains(e.relatedTarget)) rootZone.classList.remove("cs-dnd-root-active");
    });
  }

  document.body.addEventListener("drop", async (e) => {
    if (!e.shiftKey || !dragId) return;
    e.preventDefault();
    clearOver();
    await postReorder({ id: dragId, newParentId: "", newSortOrder: 0 });
    location.reload();
  });
})();
</script>
</body>
</html>

</html>












