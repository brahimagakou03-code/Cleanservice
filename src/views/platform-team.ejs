<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Équipe siège — Clean Service</title>
  <%- include("partials/favicon") %>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/public/styles/app.css" rel="stylesheet">
</head>
<body class="bg-light">
<%- include("partials/dashboard-header") %>
<div class="container py-4">
  <h1 class="h3 cs-page-title mb-2">Administrateurs Clean Service</h1>
  <p class="text-muted small mb-4">Comptes rattachés au siège (<strong>profil <%= fr.role("PLATFORM_ADMIN") %></strong>), distincts des franchisés.</p>

  <% if (typeof teamSuccess !== "undefined" && teamSuccess) { %>
    <div class="alert alert-success" role="alert"><%= teamSuccess %></div>
  <% } %>
  <% if (typeof teamAlert !== "undefined" && teamAlert) { %>
    <div class="alert alert-warning" role="alert"><%= teamAlert %></div>
  <% } %>

  <div class="card cs-tool-card mb-4">
    <div class="card-header">Créer un administrateur plateforme (mot de passe immédiat)</div>
    <div class="card-body">
      <form method="POST" action="/dashboard/platform/users/create" class="row g-3 align-items-end">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <div class="col-md-3">
          <label class="form-label small fw-semibold">E-mail <span class="text-danger">*</span></label>
          <input class="form-control" type="email" name="email" required placeholder="admin@clean-service.fr" />
        </div>
        <div class="col-md-2">
          <label class="form-label small fw-semibold">Prénom</label>
          <input class="form-control" name="firstName" placeholder="Prénom" />
        </div>
        <div class="col-md-2">
          <label class="form-label small fw-semibold">Nom</label>
          <input class="form-control" name="lastName" placeholder="Nom" />
        </div>
        <div class="col-md-2">
          <label class="form-label small fw-semibold">Rôle</label>
          <select class="form-select" name="role">
            <% (assignableRoles || []).forEach(function(r) { %>
              <option value="<%= r %>"><%= fr.role(r) %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-3">
          <label class="form-label small fw-semibold">Mot de passe <span class="text-danger">*</span></label>
          <input class="form-control" type="password" name="password" required minlength="8" />
        </div>
        <div class="col-md-3">
          <label class="form-label small fw-semibold">Confirmer mot de passe <span class="text-danger">*</span></label>
          <input class="form-control" type="password" name="passwordConfirm" required minlength="8" />
        </div>
        <div class="col-12">
          <button type="submit" class="btn btn-success">Créer le compte admin</button>
        </div>
      </form>
      <p class="small text-muted mt-2 mb-0">Ce mode crée directement le compte (Supabase Auth + utilisateur interne), sans e-mail d’invitation.</p>
    </div>
  </div>

  <div class="card cs-tool-card mb-4">
    <div class="card-header">Inviter un administrateur plateforme</div>
    <div class="card-body">
      <form method="POST" action="/dashboard/platform/users/invite" class="row g-3 align-items-end">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <div class="col-md-4">
          <label class="form-label small fw-semibold">E-mail <span class="text-danger">*</span></label>
          <input class="form-control" type="email" name="email" required placeholder="admin@clean-service.fr" />
        </div>
        <div class="col-md-3">
          <label class="form-label small fw-semibold">Prénom</label>
          <input class="form-control" name="firstName" placeholder="Prénom" />
        </div>
        <div class="col-md-3">
          <label class="form-label small fw-semibold">Nom</label>
          <input class="form-control" name="lastName" placeholder="Nom" />
        </div>
        <div class="col-md-2">
          <label class="form-label small fw-semibold">Rôle</label>
          <select class="form-select" name="role">
            <% (assignableRoles || []).forEach(function(r) { %>
              <option value="<%= r %>"><%= fr.role(r) %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-12">
          <button type="submit" class="btn btn-primary">Envoyer l’invitation</button>
        </div>
      </form>
    </div>
  </div>

  <div class="card cs-tool-card mb-4">
    <div class="card-header">Créer un accès admin boutique</div>
    <div class="card-body">
      <form method="POST" action="/dashboard/platform/shop-admins/create" class="row g-3 align-items-end">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <div class="col-md-3">
          <label class="form-label small fw-semibold">Boutique <span class="text-danger">*</span></label>
          <select class="form-select" name="organizationId" required>
            <option value="">Choisir une boutique...</option>
            <% (organizations || []).forEach(function(org) { %>
              <option value="<%= org.id %>"><%= org.name %> (<%= org.slug %>)</option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-3">
          <label class="form-label small fw-semibold">E-mail <span class="text-danger">*</span></label>
          <input class="form-control" type="email" name="email" required placeholder="admin.boutique@exemple.fr" />
        </div>
        <div class="col-md-2">
          <label class="form-label small fw-semibold">Prénom</label>
          <input class="form-control" name="firstName" placeholder="Prénom" />
        </div>
        <div class="col-md-2">
          <label class="form-label small fw-semibold">Nom</label>
          <input class="form-control" name="lastName" placeholder="Nom" />
        </div>
        <div class="col-md-2">
          <label class="form-label small fw-semibold">Mot de passe <span class="text-danger">*</span></label>
          <input class="form-control" type="password" name="password" minlength="8" required />
        </div>
        <div class="col-md-2">
          <label class="form-label small fw-semibold">Confirmer <span class="text-danger">*</span></label>
          <input class="form-control" type="password" name="passwordConfirm" minlength="8" required />
        </div>
        <div class="col-12">
          <button type="submit" class="btn btn-primary">Créer accès admin boutique</button>
        </div>
      </form>
      <p class="small text-muted mt-2 mb-0">Ce compte pourra se connecter via <code>/admin/login</code> et accéder au dashboard de la boutique.</p>
    </div>
  </div>

  <div class="card cs-tool-card">
    <div class="card-header">Membres siège</div>
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="cs-table-tools mb-0">
          <thead>
            <tr>
              <th>Nom</th>
              <th>E-mail</th>
              <th>Rôle</th>
              <th>Statut</th>
              <th class="text-end">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% (members || []).forEach(function(m) { %>
              <tr>
                <td class="fw-medium"><%= m.firstName %> <%= m.lastName %></td>
                <td><%= m.email %></td>
                <td>
                  <form method="POST" action="/dashboard/platform/users/<%= m.id %>/role" class="d-flex flex-wrap align-items-center gap-2">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                    <select class="form-select form-select-sm" name="role" style="max-width:16rem">
                      <optgroup label="Rôles siège">
                      <% (assignableRoles || []).forEach(function(r) { %>
                        <option value="<%= r %>" <%= m.role === r ? "selected" : "" %>><%= fr.role(r) %></option>
                      <% }) %>
                      </optgroup>
                      <optgroup label="Rôles boutique">
                      <% (shopAssignableRoles || []).forEach(function(r) { %>
                        <option value="<%= r %>" <%= m.role === r ? "selected" : "" %>><%= fr.role(r) %> (boutique)</option>
                      <% }) %>
                      </optgroup>
                    </select>
                    <select class="form-select form-select-sm" name="organizationId" style="max-width:16rem">
                      <option value="">Boutique (si rôle boutique)</option>
                      <% (organizations || []).forEach(function(org) { %>
                        <option value="<%= org.id %>" <%= m.organizationId === org.id ? "selected" : "" %>><%= org.name %></option>
                      <% }) %>
                    </select>
                    <button type="submit" class="btn btn-sm btn-outline-primary">Mettre à jour</button>
                  </form>
                </td>
                <td>
                  <% if (m.isActive) { %>
                    <span class="badge text-bg-success">Actif</span>
                  <% } else { %>
                    <span class="badge text-bg-secondary">Inactif</span>
                  <% } %>
                </td>
                <td class="text-end">
                  <form method="POST" action="/dashboard/platform/users/<%= m.id %>/toggle-active" class="d-inline">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                    <button type="submit" class="btn btn-sm <%= m.isActive ? "btn-outline-danger" : "btn-outline-success" %>">
                      <%= m.isActive ? "Désactiver" : "Activer" %>
                    </button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <div class="card cs-tool-card mt-4">
    <div class="card-header">Accès admin boutique</div>
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="cs-table-tools mb-0">
          <thead>
            <tr>
              <th>Boutique</th>
              <th>Nom</th>
              <th>E-mail</th>
              <th>Rôle</th>
              <th>Statut</th>
              <th class="text-end">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% (shopAccessUsers || []).forEach(function(m) { %>
              <tr>
                <td><%= m.organization?.name || "-" %></td>
                <td class="fw-medium"><%= m.firstName %> <%= m.lastName %></td>
                <td><%= m.email %></td>
                <td><%= fr.role(m.role) %></td>
                <td>
                  <% if (m.isActive) { %>
                    <span class="badge text-bg-success">Actif</span>
                  <% } else { %>
                    <span class="badge text-bg-secondary">Inactif</span>
                  <% } %>
                </td>
                <td class="text-end">
                  <form method="POST" action="/dashboard/platform/shop-admins/<%= m.id %>/delete" class="d-inline">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                    <button type="submit" class="btn btn-sm btn-outline-danger">Supprimer accès</button>
                  </form>
                </td>
              </tr>
            <% }) %>
            <% if (!shopAccessUsers || !shopAccessUsers.length) { %>
              <tr>
                <td colspan="6" class="text-muted">Aucun accès admin boutique créé depuis le siège.</td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <p class="mt-4 mb-0 d-flex flex-wrap gap-2">
    <a class="btn btn-outline-primary" href="/dashboard/platform/organizations">Franchisés</a>
    <a class="btn btn-outline-secondary" href="/dashboard">Tableau de bord siège</a>
  </p>
</div>
</body>
</html>
