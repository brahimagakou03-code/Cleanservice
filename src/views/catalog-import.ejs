<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Importation du catalogue CSV</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/public/styles/app.css" rel="stylesheet">
</head>
<body class="bg-light">
<%- include("partials/dashboard-header") %>
<div class="container py-4">
  <h1 class="h3 cs-page-title mb-4">Importation du catalogue CSV</h1>

  <div class="card cs-tool-card mb-4">
    <div class="card-header">Fichier à importer</div>
    <div class="card-body">
      <form method="POST" action="/dashboard/catalog/import/preview" enctype="multipart/form-data">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <label class="form-label fw-semibold small">Fichier CSV <span class="text-danger">*</span></label>
        <input class="form-control mb-3" type="file" name="file" accept=".csv" required />
        <button type="submit" class="btn btn-primary">Prévisualiser</button>
      </form>
    </div>
  </div>

  <% if (report) { %>
    <div class="alert <%= report.failed ? 'alert-warning' : 'alert-success' %> border-0 shadow-sm mb-4">
      Importation : <strong><%= report.imported %></strong> réussies, <strong><%= report.failed %></strong> erreurs
    </div>
    <% if (report.errors?.length) { %>
      <div class="card cs-tool-card mb-4">
        <div class="card-header text-danger">Détail des erreurs</div>
        <div class="card-body">
          <ul class="mb-0 small">
            <% report.errors.forEach(function(e){ %><li>Ligne <%= e.row %> : <%= e.message %></li><% }) %>
          </ul>
        </div>
      </div>
    <% } %>
  <% } %>

  <% if (rows?.length) { %>
    <div class="card cs-tool-card mb-4">
      <div class="card-header">Correspondance des colonnes</div>
      <div class="card-body">
        <form method="POST" action="/dashboard/catalog/import/commit">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <input type="hidden" name="rawJson" value='<%= rawJson %>' />
          <div class="row g-3">
            <% function mapper(name, label){ %>
              <div class="col-md-3">
                <label class="form-label small fw-semibold"><%= label %></label>
                <select class="form-select form-select-sm" name="<%= name %>">
                  <option value="">(vide)</option>
                  <% headers.forEach(function(h){ %><option value="<%= h %>"><%= h %></option><% }) %>
                </select>
              </div>
            <% } %>
            <% mapper("mapSku","Référence (SKU)"); mapper("mapName","Nom"); mapper("mapDescription","Description"); mapper("mapUnit","Unité"); %>
            <% mapper("mapPrice","Prix HT"); mapper("mapVat","TVA"); mapper("mapActive","Actif"); mapper("mapMinQty","Qté min"); mapper("mapStock","Stock"); %>
          </div>
          <button type="submit" class="btn btn-success mt-4">Importer</button>
        </form>
      </div>
    </div>
    <div class="card cs-tool-card">
      <div class="card-header">Aperçu des données</div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-sm table-hover align-middle mb-0">
            <thead class="table-light">
              <tr>
                <% headers.forEach(function(h){ %><th class="small text-uppercase text-muted"><%= h %></th><% }) %>
              </tr>
            </thead>
            <tbody>
              <% rows.forEach(function(r){ %>
                <tr>
                  <% headers.forEach(function(h){ %><td class="small"><%= r[h] %></td><% }) %>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  <% } %>

  <p class="mt-4 mb-0"><a class="btn btn-outline-secondary" href="/dashboard/catalog">← Retour au catalogue</a></p>
</div>
</body>
</html>
