<!doctype html>
<html lang="fr"><head><meta charset="UTF-8"><title>Factures</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"><link href="/public/styles/app.css" rel="stylesheet"></head>
<body class="bg-light"><%- include("partials/dashboard-header") %><div class="container py-4">
  <div class="d-flex justify-content-between mb-3"><h1 class="h3">Facturation</h1><a class="btn btn-primary" href="/dashboard/invoices/new">Nouvelle facture</a></div>
  <div class="row g-2 mb-3">
    <div class="col-md-4"><div class="card p-3"><strong>Total facture ce mois</strong><div><%= indicators.invoicedMonth %> EUR</div></div></div>
    <div class="col-md-4"><div class="card p-3"><strong>Total encaisse</strong><div><%= indicators.paidTotal %> EUR</div></div></div>
    <div class="col-md-4"><div class="card p-3"><strong>Total en retard</strong><div class="text-danger"><%= indicators.overdueTotal %> EUR</div></div></div>
  </div>
  <form class="row g-2 mb-3">
    <div class="col-md-2"><input class="form-control" name="q" value="<%= filters.q %>" placeholder="Numéro/client"></div>
    <div class="col-md-2"><select class="form-select" name="status"><option value="">Statut</option><% statusValues.forEach(function(s){ %><option value="<%= s %>" <%= filters.status===s?'selected':'' %>><%= fr.invoiceStatus(s) %></option><% }) %></select></div>
    <div class="col-md-2"><select class="form-select" name="type"><option value="">Type</option><% typeValues.forEach(function(t){ %><option value="<%= t %>" <%= filters.type===t?'selected':'' %>><%= fr.invoiceType(t) %></option><% }) %></select></div>
    <div class="col-md-2"><select class="form-select" name="customerId"><option value="">Client</option><% customers.forEach(function(c){ %><option value="<%= c.id %>" <%= filters.customerId===c.id?'selected':'' %>><%= c.companyName %></option><% }) %></select></div>
    <div class="col-md-2"><input class="form-control" type="date" name="fromDate" value="<%= filters.fromDate %>"></div>
    <div class="col-md-2"><input class="form-control" type="date" name="toDate" value="<%= filters.toDate %>"></div>
    <div class="col-md-2"><button class="btn btn-dark w-100">Filtrer</button></div>
  </form>
  <% const color = { PAID:'success', PARTIALLY_PAID:'warning', SENT:'warning', DRAFT:'secondary', OVERDUE:'danger', CANCELLED:'secondary' }; %>
  <table class="table table-striped bg-white">
    <thead><tr><th>Numéro</th><th>Client</th><th>Type</th><th>Statut</th><th>Émission</th><th>Échéance</th><th>TTC</th><th>Payé</th><th>Reste</th></tr></thead>
    <tbody><% invoices.forEach(function(i){ %><tr><td><a href="/dashboard/invoices/<%= i.id %>"><%= i.number || "(brouillon)" %></a></td><td><%= i.customer.companyName %></td><td><%= fr.invoiceType(i.type) %></td><td><span class="badge text-bg-<%= color[i.status] || 'secondary' %>"><%= fr.invoiceStatus(i.status) %></span></td><td><%= i.issuedAt ? i.issuedAt.toISOString().slice(0,10) : "-" %></td><td><%= i.dueAt ? i.dueAt.toISOString().slice(0,10) : "-" %></td><td><%= i.totalTtc %></td><td><%= i.amountPaid %></td><td><%= i.amountDue %></td></tr><% }) %></tbody>
  </table>
</div></body></html>
