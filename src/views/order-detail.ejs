<!doctype html>
<html lang="fr"><head><meta charset="UTF-8"><title>Commande <%= order.number %></title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"><link href="/public/styles/app.css" rel="stylesheet">
<style>
@media print {
  .no-print { display: none !important; }
  body { background: #fff !important; }
  .container { max-width: 100% !important; padding-top: 0 !important; }
  .order-bc-sheet { max-width: 100% !important; padding: 0 !important; margin: 0 !important; }
  #bon-commande.bc-doc { box-shadow: none !important; border: 1px solid #000 !important; padding: 10px 12px !important; border-radius: 0 !important; }
}
</style>
</head>
<body class="bg-light">
<div class="no-print"><%- include("partials/dashboard-header") %></div>
<div class="container py-4">
  <div class="no-print mb-3">
    <h1 class="h3"><%= order.number %></h1>
    <p class="mb-0">Client: <strong><%= order.customer.companyName %></strong> | Statut: <span class="badge text-bg-primary"><%= fr.orderStatus(order.status) %></span></p>
  </div>

  <div class="order-bc-sheet">
    <%- include("partials/order-purchase-order", { order, organization, deliverySite, billingSite, lineRows, vatRows, remiseTotale }) %>
  </div>

  <div class="no-print mt-4">
    <div class="card border-0 shadow-sm cs-order-status-card mb-4">
      <div class="card-body p-3 p-md-4">
        <h2 class="h6 text-uppercase text-muted mb-3 cs-order-section-title">Historique des statuts</h2>
        <% if (!order.statusHistory || !order.statusHistory.length) { %>
          <p class="text-muted small mb-0">Aucun historique enregistré.</p>
        <% } else { %>
        <ul class="list-unstyled mb-0 cs-order-timeline">
          <% order.statusHistory.forEach(function(h, idx){ %>
            <% 
              var who = h.changedBy ? (h.changedBy.firstName + " " + h.changedBy.lastName).trim() : "Système";
              var when = new Date(h.createdAt).toLocaleString("fr-FR", { dateStyle: "short", timeStyle: "short" });
            %>
            <li class="cs-order-timeline-item d-flex gap-3 <%= idx === order.statusHistory.length - 1 ? 'is-last' : '' %>">
              <div class="cs-order-timeline-marker flex-shrink-0" aria-hidden="true"></div>
              <div class="flex-grow-1 min-w-0 pb-3">
                <div class="d-flex flex-wrap align-items-baseline gap-2 mb-1">
                  <strong class="text-dark"><%= fr.orderStatus(h.toStatus) %></strong>
                  <span class="small text-muted"><%= when %></span>
                </div>
                <p class="small text-muted mb-0">Par <span class="text-body"><%= who %></span><% if (h.comment) { %> · <span class="fst-italic"><%= h.comment %></span><% } %></p>
              </div>
            </li>
          <% }) %>
        </ul>
        <% } %>
      </div>
    </div>
    <% 
      function olFmt2(n) {
        var x = Number(n);
        if (isNaN(x)) return "—";
        return x.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, "\u202f");
      }
      function olQty(n) {
        var x = Number(n);
        if (isNaN(x)) return "—";
        if (Math.abs(x - Math.round(x)) < 1e-9) return String(Math.round(x));
        return olFmt2(x);
      }
      function olPct(n) {
        var x = Number(n);
        if (isNaN(x)) return "—";
        var s = x.toFixed(2).replace(/\.?0+$/, "");
        return s + "\u00a0%";
      }
    %>
    <div class="cs-order-lines-card">
      <h2 class="cs-ol-title">Synthèse des lignes</h2>
      <div class="table-responsive">
        <table class="cs-order-lines-table">
          <thead>
            <tr>
              <th class="cs-ol-th-ref" scope="col">Réf.</th>
              <th scope="col">Nom</th>
              <th class="cs-ol-num" scope="col">Qté</th>
              <th class="cs-ol-num" scope="col">PU HT</th>
              <th class="cs-ol-num" scope="col">Remise</th>
              <th class="cs-ol-num" scope="col">TVA</th>
              <th class="cs-ol-num" scope="col">Total TTC</th>
            </tr>
          </thead>
          <tbody>
            <% order.lines.forEach(function(l){ %>
            <tr>
              <td class="cs-ol-td-ref"><span class="cs-ol-ref"><%= l.productSkuSnapshot %></span></td>
              <td><span class="cs-ol-name"><%= l.productNameSnapshot %></span></td>
              <td class="cs-ol-num"><%= olQty(l.quantity) %></td>
              <td class="cs-ol-num"><%= olFmt2(l.unitPriceHt) %></td>
              <td class="cs-ol-num"><%= olPct(l.discountPercent) %></td>
              <td class="cs-ol-num"><%= olPct(l.vatRate) %></td>
              <td class="cs-ol-num"><%= olFmt2(l.lineTotalTtc) %></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <div class="cs-order-totals-bar">
        <div class="cs-order-total-cell">
          <span class="cs-order-total-label">Total HT</span>
          <span class="cs-order-total-value"><%= olFmt2(order.totalHt) %>&nbsp;€</span>
        </div>
        <div class="cs-order-total-cell">
          <span class="cs-order-total-label">TVA</span>
          <span class="cs-order-total-value"><%= olFmt2(order.totalTva) %>&nbsp;€</span>
        </div>
        <div class="cs-order-total-cell cs-order-total-cell--ttc">
          <span class="cs-order-total-label">Total TTC</span>
          <span class="cs-order-total-value"><%= olFmt2(order.totalTtc) %>&nbsp;€</span>
        </div>
      </div>
    </div>

    <div class="card border-0 shadow-sm cs-order-actions-card mb-3">
      <div class="card-body p-3 p-md-4">
        <h2 class="h6 text-uppercase text-muted mb-3 cs-order-section-title">Actions</h2>

        <div class="cs-order-actions-toolbar d-flex flex-wrap align-items-center gap-2 mb-4 pb-3 border-bottom">
          <span class="small text-muted me-1">Documents</span>
          <button type="button" class="btn btn-outline-primary" onclick="window.print()">Imprimer le bon de commande</button>
          <a class="btn btn-outline-dark" href="/dashboard/orders/<%= order.id %>/pdf">Télécharger le PDF</a>
        </div>

        <% if (actions.includes('approve') || actions.includes('reject') || actions.includes('cancel')) { %>
        <% var showBothPanels = actions.includes('approve') && (actions.includes('reject') || actions.includes('cancel')); %>
        <div class="row g-3 mb-4">
          <% if (actions.includes('approve')) { %>
          <div class="<%= showBothPanels ? 'col-12 col-lg-6' : 'col-12' %>">
            <div class="border rounded-3 p-3 h-100 cs-order-action-panel cs-order-action-panel--approve">
              <h3 class="h6 mb-2">Approuver la commande</h3>
              <p class="small text-muted mb-2">Valider la commande côté fournisseur (commentaire optionnel).</p>
              <form method="POST" action="/dashboard/orders/<%= order.id %>/status" class="d-flex flex-column gap-2">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <input type="hidden" name="toStatus" value="CONFIRMED">
                <label class="form-label small mb-0" for="approve-comment">Commentaire</label>
                <textarea class="form-control form-control-sm" id="approve-comment" name="comment" rows="2" placeholder="Ex. accord prix, consigne livraison…"></textarea>
                <button type="submit" class="btn btn-success align-self-start">Approuver</button>
              </form>
            </div>
          </div>
          <% } %>
          <% if (actions.includes('reject') || actions.includes('cancel')) { %>
          <div class="<%= showBothPanels ? 'col-12 col-lg-6' : 'col-12' %>">
            <div class="border rounded-3 p-3 h-100 cs-order-action-panel cs-order-action-panel--reject">
              <h3 class="h6 mb-2">Annuler ou rejeter</h3>
              <p class="small text-muted mb-2">Le motif est obligatoire ; il pourra être communiqué au client.</p>
              <form method="POST" action="/dashboard/orders/<%= order.id %>/status" class="d-flex flex-column gap-2">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <input type="hidden" name="toStatus" value="CANCELLED">
                <label class="form-label small mb-0" for="cancel-comment">Motif <span class="text-danger">*</span></label>
                <textarea class="form-control form-control-sm" id="cancel-comment" name="comment" rows="2" placeholder="Ex. rupture de stock, refus prix…" required></textarea>
                <button type="submit" class="btn btn-danger align-self-start">Annuler / rejeter</button>
              </form>
            </div>
          </div>
          <% } %>
        </div>
        <% } %>

        <div class="d-flex flex-wrap align-items-center gap-2">
          <% if (actions.includes('delete')) { %><form method="POST" action="/dashboard/orders/<%= order.id %>/delete" class="m-0"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="btn btn-outline-danger btn-sm">Supprimer brouillon</button></form><% } %>
          <% if (actions.includes('confirm')) { %><form method="POST" action="/dashboard/orders/<%= order.id %>/status" class="m-0"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><input type="hidden" name="toStatus" value="CONFIRMED"><button class="btn btn-primary btn-sm">Confirmer</button></form><% } %>
          <% if (actions.includes('prepare')) { %><form method="POST" action="/dashboard/orders/<%= order.id %>/status" class="m-0"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><input type="hidden" name="toStatus" value="IN_PREPARATION"><button class="btn btn-outline-primary btn-sm">En préparation</button></form><% } %>
          <% if (actions.includes('ship')) { %><form method="POST" action="/dashboard/orders/<%= order.id %>/status" class="m-0"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><input type="hidden" name="toStatus" value="SHIPPED"><button class="btn btn-outline-primary btn-sm">Expédier</button></form><% } %>
          <% if (actions.includes('deliver')) { %><form method="POST" action="/dashboard/orders/<%= order.id %>/status" class="m-0"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><input type="hidden" name="toStatus" value="DELIVERED"><button class="btn btn-outline-primary btn-sm">Livrer</button></form><% } %>
          <% if (actions.includes('duplicate')) { %><form method="POST" action="/dashboard/orders/<%= order.id %>/duplicate" class="m-0"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="btn btn-outline-secondary btn-sm">Dupliquer</button></form><% } %>
          <% if (actions.includes('generate_invoice')) { %><form method="POST" action="/dashboard/invoices/from-order/<%= order.id %>" class="m-0"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="btn btn-warning btn-sm">Générer la facture</button></form><% } %>
        </div>
      </div>
    </div>

    <p class="mb-0"><a class="btn btn-outline-secondary" href="/dashboard/orders">← Retour à la liste</a></p>
  </div>
</div></body></html>
